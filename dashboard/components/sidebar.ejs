<aside class="hidden w-80 shrink-0 flex-col bg-primary px-6 py-8 text-white lg:flex">
  <a href="<%= basePath %>/dashboard" class="flex items-center gap-3">
    <span class="flex h-12 w-12 items-center justify-center rounded-2xl bg-secondary text-lg font-extrabold text-primary">KX</span>
    <span>
      <span class="block font-display text-lg font-bold">Kuwexa</span>
      <span class="block text-xs uppercase tracking-[0.25em] text-white/50"><%= areaLabel %> Console</span>
    </span>
  </a>
  <div class="mt-12 rounded-3xl border border-white/10 bg-white/5 p-5">
    <p class="text-xs uppercase tracking-[0.3em] text-secondary">Signed In</p>
    <p class="mt-3 font-display text-xl font-bold"><%= currentUser.name %></p>
    <p class="text-sm text-white/60"><%= currentUser.email %></p>
  </div>
  <nav class="mt-10 space-y-2">
    <% menu.forEach((item) => { %>
      <a href="<%= item.href %>" class="block rounded-2xl px-4 py-3 text-sm font-semibold transition <%= activeMenu === item.label ? 'bg-secondary text-primary' : 'text-white/75 hover:bg-white/10 hover:text-white' %>"><%= item.label %></a>
    <% }) %>
  </nav>
</aside>
