<%- include('layout-start') %>
<% if (notice) { %>
  <div class="mb-6 rounded-3xl bg-emerald-50 px-5 py-4 text-sm font-semibold text-emerald-700"><%= notice.message %></div>
<% } %>
<div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
  <% cards.forEach((item) => { %>
    <div class="rounded-3xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
      <p class="text-sm text-slate-500"><%= item.label %></p>
      <p class="mt-3 font-display text-4xl font-bold text-primary"><%= item.value %></p>
    </div>
  <% }) %>
</div>

<section class="mt-6 rounded-3xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
  <div class="flex items-center justify-between gap-4">
    <div>
      <h2 class="font-display text-2xl font-bold text-slate-900">Workspace Modules</h2>
      <p class="mt-2 text-sm text-slate-500">Quick access to the modules available for your role, including Team management.</p>
    </div>
  </div>
  <div class="mt-6 grid gap-4 md:grid-cols-2 xl:grid-cols-4">
    <% menu.forEach((item) => { %>
      <a href="<%= item.href %>" class="rounded-2xl border border-slate-200 bg-slate-50 px-5 py-4 text-sm font-semibold text-slate-700 transition hover:border-secondary hover:bg-secondary/10 hover:text-primary">
        <span class="block text-xs uppercase tracking-[0.2em] text-slate-400">Module</span>
        <span class="mt-2 block font-display text-xl font-bold text-primary"><%= item.label %></span>
      </a>
    <% }) %>
  </div>
</section>

<div class="mt-6 grid gap-6 xl:grid-cols-[1.2fr,0.8fr]">
  <section class="rounded-3xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
    <div class="mb-5 flex items-center justify-between">
      <div>
        <h2 class="font-display text-2xl font-bold text-slate-900">Traffic Summary</h2>
        <p class="mt-2 text-sm text-slate-500">Recent website traffic events captured by the visitor tracker.</p>
      </div>
    </div>
    <% const maxVisits = Math.max(...trafficSeries.map((point) => Number(point.visits)), 1); %>
    <div class="space-y-4">
      <% trafficSeries.forEach((point) => { %>
        <div>
          <div class="mb-1 flex items-center justify-between text-sm">
            <span class="text-slate-500"><%= helpers.formatDate(point.day) %></span>
            <span class="font-semibold text-slate-900"><%= point.visits %> visits</span>
          </div>
          <div class="h-3 overflow-hidden rounded-full bg-slate-100">
            <div class="h-full rounded-full bg-secondary" style="width: <%= Math.max((Number(point.visits) / maxVisits) * 100, 6) %>%"></div>
          </div>
        </div>
      <% }) %>
      <% if (!trafficSeries.length) { %>
        <p class="text-sm text-slate-500">Traffic data will appear after public pages receive visits.</p>
      <% } %>
    </div>
  </section>
  <section class="rounded-3xl bg-primary p-6 text-white shadow-sm">
    <p class="text-xs uppercase tracking-[0.3em] text-secondary">Execution Queue</p>
    <div class="mt-5 space-y-4 text-sm">
      <div>
        <p class="font-semibold text-white">Latest Leads</p>
        <% latestLeads.slice(0, 4).forEach((lead) => { %>
          <div class="mt-3 rounded-2xl border border-white/10 bg-white/5 p-3">
            <div class="flex items-center justify-between">
              <span><%= lead.name %></span>
              <span class="text-xs uppercase text-secondary"><%= lead.status %></span>
            </div>
            <p class="mt-1 text-white/60"><%= lead.email %></p>
          </div>
        <% }) %>
      </div>
      <div>
        <p class="font-semibold text-white">Latest Applications</p>
        <% latestApplications.slice(0, 4).forEach((application) => { %>
          <div class="mt-3 rounded-2xl border border-white/10 bg-white/5 p-3">
            <div class="flex items-center justify-between">
              <span><%= application.name %></span>
              <span class="text-xs uppercase text-secondary"><%= application.status %></span>
            </div>
            <p class="mt-1 text-white/60"><%= application.job_title %></p>
          </div>
        <% }) %>
      </div>
    </div>
  </section>
</div>

<div class="mt-6 grid gap-6 xl:grid-cols-2">
  <section class="rounded-3xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
    <h2 class="font-display text-2xl font-bold text-slate-900">Recent Posts</h2>
    <div class="mt-5 space-y-4">
      <% latestPosts.forEach((post) => { %>
        <div class="rounded-2xl border border-slate-200 p-4">
          <div class="flex items-center justify-between gap-4">
            <div>
              <p class="font-semibold text-slate-900"><%= post.title %></p>
              <p class="mt-1 text-sm text-slate-500"><%= post.category || 'Uncategorized' %></p>
            </div>
            <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-600"><%= post.status %></span>
          </div>
        </div>
      <% }) %>
      <% if (!latestPosts.length) { %>
        <p class="text-sm text-slate-500">No posts created yet.</p>
      <% } %>
    </div>
  </section>
  <section class="rounded-3xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
    <h2 class="font-display text-2xl font-bold text-slate-900">Featured Projects</h2>
    <div class="mt-5 space-y-4">
      <% featuredProjects.forEach((project) => { %>
        <div class="rounded-2xl border border-slate-200 p-4">
          <div class="flex items-center justify-between gap-4">
            <div>
              <p class="font-semibold text-slate-900"><%= project.title %></p>
              <p class="mt-1 text-sm text-slate-500"><%= project.client || 'Internal' %></p>
            </div>
            <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-600"><%= project.category || 'General' %></span>
          </div>
        </div>
      <% }) %>
      <% if (!featuredProjects.length) { %>
        <p class="text-sm text-slate-500">No projects published yet.</p>
      <% } %>
    </div>
  </section>
</div>
<%- include('layout-end') %>
