<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= pageTitle %> | CodexWebz</title>
  <% if (siteSettings?.favicon_path) { %>
    <link rel="icon" href="<%= siteSettings.favicon_path %>">
    <link rel="shortcut icon" href="<%= siteSettings.favicon_path %>">
  <% } %>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Space+Grotesk:wght@500;700&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            primary: '<%= siteSettings?.primary_color || "#00240a" %>',
            secondary: '<%= siteSettings?.secondary_color || "#dbab0d" %>'
          },
          fontFamily: {
            sans: ['Manrope', 'sans-serif'],
            display: ['Space Grotesk', 'sans-serif']
          }
        }
      }
    };
  </script>
  <link rel="stylesheet" href="/styles/main.css">
</head>
<body class="min-h-screen bg-slate-100 font-sans text-slate-900">
  <div class="flex min-h-screen">
    <%- include('sidebar') %>
    <div class="flex min-h-screen flex-1 flex-col">
      <%- include('topbar') %>
      <main class="flex-1 px-6 py-8 lg:px-10">
