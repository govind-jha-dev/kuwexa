<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= pageTitle %> | Kuwexa</title>
  <% if (siteSettings?.favicon_path) { %>
    <link rel="icon" href="<%= siteSettings.favicon_path %>">
    <link rel="shortcut icon" href="<%= siteSettings.favicon_path %>">
  <% } %>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;600;700;800&family=Syne:wght@700&display=swap" rel="stylesheet">
  <style>
    :root {
      --primary: <%= siteSettings?.primary_color || '#0d2d24' %>;
      --secondary: <%= siteSettings?.secondary_color || '#f1b24a' %>;
      --surface: #f3eee2;
    }
  </style>
  <link rel="preload" href="/styles/tailwind.css" as="style">
  <link rel="stylesheet" href="/styles/tailwind.css">
  <link rel="stylesheet" href="/styles/main.css">
</head>
<body class="min-h-screen bg-slate-100 font-sans text-slate-900">
  <div class="flex min-h-screen">
    <%- include('sidebar') %>
    <div class="flex min-h-screen flex-1 flex-col">
      <%- include('topbar') %>
      <main class="flex-1 px-6 py-8 lg:px-10">
