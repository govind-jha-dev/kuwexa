<header class="border-b border-slate-200 bg-white/80 backdrop-blur">
  <div class="flex items-center justify-between px-6 py-5 lg:px-10">
    <div>
      <p class="text-xs uppercase tracking-[0.35em] text-slate-400"><%= areaLabel %> Workspace</p>
      <h1 class="mt-2 font-display text-3xl font-bold text-slate-900"><%= pageTitle %></h1>
    </div>
    <form method="post" action="/logout">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <button type="submit" class="rounded-full border border-slate-200 px-4 py-2 text-sm font-semibold text-slate-700 hover:border-secondary hover:text-primary">Logout</button>
    </form>
  </div>
  <div class="overflow-x-auto px-6 pb-4 lg:hidden">
    <div class="flex gap-2">
      <% menu.forEach((item) => { %>
        <a href="<%= item.href %>" class="whitespace-nowrap rounded-full px-4 py-2 text-sm font-semibold <%= activeMenu === item.label ? 'bg-primary text-white' : 'bg-slate-100 text-slate-700' %>"><%= item.label %></a>
      <% }) %>
    </div>
  </div>
</header>
