<%- include('layout-start') %>
<div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
  <div class="rounded-3xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
    <p class="text-sm text-slate-500">Visitors</p>
    <p class="mt-3 font-display text-4xl font-bold text-primary"><%= overview.visitors %></p>
  </div>
  <div class="rounded-3xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
    <p class="text-sm text-slate-500">Leads</p>
    <p class="mt-3 font-display text-4xl font-bold text-primary"><%= overview.leads %></p>
  </div>
  <div class="rounded-3xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
    <p class="text-sm text-slate-500">Applications</p>
    <p class="mt-3 font-display text-4xl font-bold text-primary"><%= overview.applications %></p>
  </div>
</div>
<div class="mt-6 grid gap-6 xl:grid-cols-[1.1fr,0.9fr]">
  <section class="rounded-3xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
    <h2 class="font-display text-2xl font-bold text-slate-900">Traffic Trend</h2>
    <% const maxVisits = Math.max(...trafficSeries.map((point) => Number(point.visits)), 1); %>
    <div class="mt-6 space-y-4">
      <% trafficSeries.forEach((point) => { %>
        <div>
          <div class="mb-1 flex items-center justify-between text-sm">
            <span class="text-slate-500"><%= helpers.formatDate(point.day) %></span>
            <span class="font-semibold text-slate-900"><%= point.visits %></span>
          </div>
          <div class="h-3 overflow-hidden rounded-full bg-slate-100">
            <div class="h-full rounded-full bg-primary" style="width: <%= Math.max((Number(point.visits) / maxVisits) * 100, 4) %>%"></div>
          </div>
        </div>
      <% }) %>
      <% if (!trafficSeries.length) { %>
        <p class="text-sm text-slate-500">Traffic data will appear here once visits are recorded.</p>
      <% } %>
    </div>
  </section>
  <section class="rounded-3xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
    <h2 class="font-display text-2xl font-bold text-slate-900">Top Pages</h2>
    <div class="mt-6 space-y-4">
      <% topPages.forEach((item) => { %>
        <div class="flex items-center justify-between rounded-2xl border border-slate-200 px-4 py-3">
          <span class="text-sm text-slate-700"><%= item.path %></span>
          <span class="rounded-full bg-secondary/15 px-3 py-1 text-xs font-semibold text-primary"><%= item.visits %> visits</span>
        </div>
      <% }) %>
      <% if (!topPages.length) { %>
        <p class="text-sm text-slate-500">No page traffic captured yet.</p>
      <% } %>
    </div>
  </section>
</div>
<%- include('layout-end') %>
