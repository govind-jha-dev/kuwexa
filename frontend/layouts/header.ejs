<% const activePath = typeof currentPath !== 'undefined' ? currentPath : ''; %>
<% const user = typeof currentUser !== 'undefined' ? currentUser : null; %>
<header class="sticky top-0 z-[120] border-b border-primary/8 bg-[rgba(246,242,233,0.94)] shadow-sm backdrop-blur-xl">
  <div class="mx-auto flex max-w-7xl items-center justify-between px-2 py-2 lg:px-4">
    <a href="/" class="flex items-center gap-3">
      <% if (siteSettings?.logo_path) { %>
        <img src="<%= siteSettings.logo_path %>" alt="<%= siteSettings?.company_name || 'CodexWebz' %> logo" class="site-logo h-12 w-auto max-w-[11rem] object-contain md:h-14">
      <% } else { %>
        <span>
          <span class="block font-display text-lg font-bold text-primary"><%= siteSettings?.company_name || 'CodexWebz' %></span>
          <span class="block text-[11px] uppercase tracking-[0.35em] text-primary/45">Technology Solutions</span>
        </span>
      <% } %>
    </a>

    <nav class="site-header__desktop-nav items-center gap-7 text-sm font-semibold text-primary/70">
      <a href="/services" class="transition <%= activePath.startsWith('/services') ? 'text-primary' : 'hover:text-primary' %>">Services</a>
      <% if (Number(siteSettings?.show_products_menu) !== 0) { %>
        <a href="/products" class="transition <%= activePath.startsWith('/products') ? 'text-primary' : 'hover:text-primary' %>">Our Products</a>
      <% } %>
      <a href="/projects" class="transition <%= activePath.startsWith('/projects') || activePath.startsWith('/portfolio') ? 'text-primary' : 'hover:text-primary' %>">Our Projects</a>
      <a href="/about-us" class="transition <%= activePath === '/about' || activePath === '/about-us' || activePath === '/about-codexwebz' ? 'text-primary' : 'hover:text-primary' %>">About Us</a>
      <a href="/team" class="transition <%= activePath === '/team' || activePath.startsWith('/team/') ? 'text-primary' : 'hover:text-primary' %>">Team</a>
      <a href="/careers" class="transition <%= activePath.startsWith('/careers') ? 'text-primary' : 'hover:text-primary' %>">Careers</a>
      <a href="/contact" class="transition <%= activePath === '/contact' ? 'text-primary' : 'hover:text-primary' %>">Contact</a>
    </nav>

    <div class="site-header__actions items-center gap-3">
      <% if (user) { %>
        <a href="<%= user.role_name === 'super_admin' ? '/admin/dashboard' : '/manager/dashboard' %>" class="rounded-full border border-primary/12 px-4 py-2 text-sm font-semibold text-primary transition hover:border-secondary hover:bg-white">Dashboard</a>
      <% } else { %>
        <a href="/login" class="rounded-full border border-primary/12 px-4 py-2 text-sm font-semibold text-primary transition hover:border-secondary hover:bg-white">Login</a>
      <% } %>
      <a href="/contact" class="rounded-full bg-primary px-5 py-2.5 text-sm font-bold text-white shadow-lg shadow-primary/15 transition hover:-translate-y-0.5 hover:bg-primary/95">Start Project</a>
    </div>

    <button type="button" class="site-header__toggle inline-flex h-12 w-12 items-center justify-center rounded-full bg-primary text-white shadow-lg shadow-primary/20" data-nav-toggle aria-label="Open navigation" aria-expanded="false" aria-controls="site-mobile-nav">
      <span class="space-y-1.5">
        <span class="block h-0.5 w-5 bg-current"></span>
        <span class="block h-0.5 w-5 bg-current"></span>
        <span class="block h-0.5 w-5 bg-current"></span>
      </span>
    </button>
  </div>

  <div id="site-mobile-nav" class="site-mobile-nav" data-nav-panel aria-hidden="true">
    <button type="button" class="site-mobile-nav__scrim" data-nav-close aria-label="Close navigation"></button>
    <div class="site-mobile-nav__panel">
      <div class="flex items-center justify-between">
        <div>
          <span class="text-xs font-bold uppercase tracking-[0.35em] text-secondary">CodexWebz</span>
          <span class="mt-2 block font-display text-2xl font-bold text-white">Menu</span>
        </div>
        <button type="button" class="site-mobile-nav__close" data-nav-close aria-label="Close navigation">&times;</button>
      </div>
      <nav class="site-mobile-nav__links">
        <a href="/services" class="site-mobile-nav__link">Services</a>
        <% if (Number(siteSettings?.show_products_menu) !== 0) { %>
          <a href="/products" class="site-mobile-nav__link">Our Products</a>
        <% } %>
        <a href="/projects" class="site-mobile-nav__link">Our Projects</a>
        <a href="/about-us" class="site-mobile-nav__link">About Us</a>
        <a href="/team" class="site-mobile-nav__link">Team</a>
        <a href="/careers" class="site-mobile-nav__link">Careers</a>
        <a href="/contact" class="site-mobile-nav__link">Contact</a>
      </nav>
      <div class="site-mobile-nav__actions">
        <% if (user) { %>
          <a href="<%= user.role_name === 'super_admin' ? '/admin/dashboard' : '/manager/dashboard' %>" class="site-mobile-nav__ghost">Dashboard</a>
        <% } else { %>
          <a href="/login" class="site-mobile-nav__ghost">Login</a>
        <% } %>
        <a href="/contact" class="site-mobile-nav__primary">Start Project</a>
      </div>
    </div>
  </div>
</header>
