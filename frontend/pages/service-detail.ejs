<%- include('../layouts/head', { title, seo }) %>
<%- include('../layouts/header') %>

<section class="mx-auto max-w-7xl px-6 py-20 lg:px-8">
  <a href="/services" class="text-sm font-bold text-primary underline decoration-secondary underline-offset-4">Back to services</a>
  <div class="mt-8 editorial-grid gap-10">
    <article class="surface-panel rounded-[2.25rem] p-8 lg:p-10">
      <div class="flex flex-wrap items-center gap-3">
        <span class="rounded-full bg-secondary/15 px-4 py-2 text-xs font-bold uppercase tracking-[0.2em] text-primary"><%= profile.category %></span>
        <span class="rounded-full bg-primary/8 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-primary/58"><%= service.icon || 'CodexWebz Service' %></span>
      </div>
      <h1 class="mt-6 font-display text-5xl font-bold leading-tight text-primary md:text-6xl"><%= service.title %></h1>
      <p class="mt-5 max-w-3xl text-lg leading-8 text-slate-600"><%= service.short_description || profile.kicker %></p>
      <% if (service.image) { %>
        <div class="mt-8 overflow-hidden rounded-[2rem] bg-slate-100 shadow-sm ring-1 ring-primary/8">
          <img
            src="<%= service.image %>"
            alt="<%= service.title %>"
            class="h-[18rem] w-full object-cover md:h-[22rem] xl:h-[26rem]"
            loading="eager"
            decoding="async">
        </div>
      <% } %>
      <div class="prose-content mt-10"><%- service.description || '<p>This service is structured to connect visual polish, CMS control, SEO readiness, and backend workflows.</p>' %></div>
    </article>

    <aside class="space-y-6">
      <div class="rounded-[2rem] bg-primary p-8 text-white">
        <p class="text-xs font-bold uppercase tracking-[0.35em] text-secondary">Service Focus</p>
        <h2 class="mt-4 font-display text-3xl font-bold"><%= profile.kicker %></h2>
        <p class="mt-4 text-sm leading-8 text-white/72">CodexWEBZ structures this service around real business requirements, practical implementation, and long-term usability after launch.</p>
        <a href="/contact" class="mt-6 inline-flex rounded-full bg-secondary px-5 py-3 text-sm font-bold text-primary">Request a Proposal</a>
      </div>

      <div class="surface-panel rounded-[2rem] p-7">
        <p class="text-xs font-bold uppercase tracking-[0.35em] text-primary/38">Deliverables</p>
        <div class="mt-5 space-y-3">
          <% profile.deliverables.forEach((item) => { %>
            <div class="rounded-[1.35rem] bg-slate-50 px-4 py-4 text-sm font-semibold text-slate-700"><%= item %></div>
          <% }) %>
        </div>
      </div>

      <div class="surface-panel rounded-[2rem] p-7">
        <p class="text-xs font-bold uppercase tracking-[0.35em] text-primary/38">Expected Outcomes</p>
        <ul class="mt-5 space-y-3 text-sm leading-7 text-slate-600">
          <% profile.outcomes.forEach((item) => { %>
            <li class="rounded-[1.35rem] bg-slate-50 px-4 py-4"><%= item %></li>
          <% }) %>
        </ul>
      </div>
    </aside>
  </div>

  <div class="mt-12 rounded-[2.2rem] bg-white p-8 shadow-sm ring-1 ring-primary/8 lg:p-10">
    <%- include('../components/section-heading', {
      eyebrow: 'Delivery Sequence',
      title: 'How this work usually gets shipped.',
      copy: 'The same implementation rhythm is used to keep design quality high and operational risk low.'
    }) %>
    <div class="mt-8 grid gap-4 md:grid-cols-2 xl:grid-cols-4">
      <% profile.process.forEach((step, index) => { %>
        <article class="reveal rounded-[1.6rem] bg-slate-50 p-5" data-reveal>
          <p class="font-display text-3xl font-bold text-secondary"><%= `0${index + 1}` %></p>
          <p class="mt-3 text-sm font-bold uppercase tracking-[0.2em] text-primary/58"><%= step %></p>
        </article>
      <% }) %>
    </div>
  </div>
</section>

<%- include('../components/team-showcase', {
  eyebrow: 'Service Team',
  title: 'Leadership and specialists who deliver this kind of work.',
  copy: 'The same team that shapes the service scope also keeps the operational system and public presentation aligned after launch.'
}) %>

<%- include('../components/site-cta', {
  eyebrow: 'Need This Service',
  title: `Want ${service.title} implemented as part of a production-ready platform?`,
  copy: 'CodexWebz can scope this service as a standalone engagement or as part of the full website and management system.',
  primaryLabel: 'Start the Conversation',
  primaryHref: '/contact',
  secondaryLabel: 'Back to Services',
  secondaryHref: '/services'
}) %>

<%- include('../layouts/footer') %>
<%- include('../layouts/scripts') %>
