<%- include('../layouts/head', { title, seo }) %>
<%- include('../layouts/header') %>

<section class="mx-auto max-w-7xl px-6 py-20 lg:px-8">
  <a href="/products" class="text-sm font-bold text-primary underline decoration-secondary underline-offset-4">Back to products</a>

  <div class="mt-8 editorial-grid gap-10">
    <article class="surface-panel rounded-[2.25rem] p-8 lg:p-10">
      <div class="flex flex-wrap items-center gap-4">
        <div class="flex h-20 w-20 items-center justify-center overflow-hidden rounded-[1.4rem] bg-slate-50 ring-1 ring-primary/8">
          <% if (product.logo) { %>
            <img src="<%= product.logo %>" alt="<%= product.name %>" class="h-14 w-14 object-contain">
          <% } else { %>
            <span class="font-display text-3xl font-bold text-primary"><%= String(product.name || 'P').charAt(0) %></span>
          <% } %>
        </div>
        <div>
          <p class="text-xs font-bold uppercase tracking-[0.35em] text-secondary">Product Overview</p>
          <h1 class="mt-3 font-display text-5xl font-bold leading-tight text-primary md:text-6xl"><%= product.name %></h1>
        </div>
      </div>
      <p class="mt-6 max-w-3xl text-lg leading-8 text-slate-600"><%= product.short_description || 'Detailed product information managed from the CodexWebz dashboard.' %></p>
      <div class="prose-content mt-10"><%- product.description || '<p>This product page is generated from the products database module.</p>' %></div>
    </article>

    <aside class="space-y-6">
      <% if (product.logo) { %>
        <img src="<%= product.logo %>" alt="<%= product.name %>" class="h-80 w-full rounded-[2rem] object-contain bg-white p-8 shadow-float ring-1 ring-primary/8">
      <% } %>
      <div class="rounded-[2rem] bg-primary p-8 text-white">
        <p class="text-xs font-bold uppercase tracking-[0.35em] text-secondary">Action</p>
        <h2 class="mt-4 font-display text-3xl font-bold">See it in action or request a guided walkthrough.</h2>
        <div class="mt-6 flex flex-wrap gap-3">
          <% if (product.demo_link) { %>
            <a href="<%= product.demo_link %>" target="_blank" rel="noreferrer" class="rounded-full bg-secondary px-5 py-3 text-sm font-bold text-primary">Open Demo</a>
          <% } %>
          <% if (product.website_link) { %>
            <a href="<%= product.website_link %>" target="_blank" rel="noreferrer" class="rounded-full border border-white/12 px-5 py-3 text-sm font-semibold text-white">Visit Website</a>
          <% } %>
          <a href="/contact" class="rounded-full border border-white/12 px-5 py-3 text-sm font-semibold text-white">Request Demo</a>
        </div>
      </div>
      <div class="surface-panel rounded-[2rem] p-7">
        <p class="text-xs font-bold uppercase tracking-[0.35em] text-primary/38">Technology Stack</p>
        <div class="mt-5 flex flex-wrap gap-3">
          <% (product.tech_stack || []).forEach((tech) => { %>
            <span class="rounded-full bg-slate-100 px-4 py-2 text-sm font-semibold text-slate-700"><%= tech %></span>
          <% }) %>
          <% if (!(product.tech_stack || []).length) { %>
            <span class="text-sm text-slate-500">Technology stack not listed.</span>
          <% } %>
        </div>
      </div>
    </aside>
  </div>

  <section class="mt-12 rounded-[2.2rem] bg-white p-8 shadow-sm ring-1 ring-primary/8 lg:p-10">
    <%- include('../components/section-heading', {
      eyebrow: 'Features',
      title: 'What this product includes.',
      copy: 'Feature lists are managed directly from the Products module in the dashboard.'
    }) %>
    <div class="mt-8 grid gap-4 md:grid-cols-2">
      <% (product.features || []).forEach((feature) => { %>
        <article class="rounded-[1.6rem] bg-slate-50 px-5 py-5 text-sm font-semibold leading-7 text-slate-700"><%= feature %></article>
      <% }) %>
      <% if (!(product.features || []).length) { %>
        <article class="rounded-[1.6rem] border border-dashed border-primary/20 bg-slate-50 px-5 py-5 text-sm text-slate-500 md:col-span-2">No feature list added yet.</article>
      <% } %>
    </div>
  </section>

  <% if ((product.images || []).length) { %>
    <section class="mt-12">
      <%- include('../components/section-heading', {
        eyebrow: 'Screenshots',
        title: 'Product gallery and UI previews.',
        copy: 'Upload screenshots from the dashboard and they render automatically here.'
      }) %>
      <div class="mt-8 grid gap-6 md:grid-cols-2">
        <% product.images.forEach((image) => { %>
          <img src="<%= image %>" alt="<%= product.name %>" class="reveal h-72 w-full rounded-[1.85rem] object-cover shadow-sm" data-reveal>
        <% }) %>
      </div>
    </section>
  <% } %>
</section>

<%- include('../components/site-cta', {
  eyebrow: 'Need a Similar Product?',
  title: 'Want CodexWebz to build a SaaS platform or a business web application like this?',
  copy: 'CodexWebz handles product pages, dashboards, APIs, and the operational CMS needed to manage the product after launch.',
  primaryLabel: 'Request Demo',
  primaryHref: '/contact',
  secondaryLabel: 'All Products',
  secondaryHref: '/products'
}) %>

<%- include('../layouts/footer') %>
<%- include('../layouts/scripts') %>
