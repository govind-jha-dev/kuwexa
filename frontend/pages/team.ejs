<%- include('../layouts/head', { title, seo }) %>
<%- include('../layouts/header') %>

<section class="kuwexa-hero text-white">
  <div class="mx-auto max-w-7xl px-6 py-20 lg:px-8 lg:py-28">
    <div class="grid gap-12 lg:grid-cols-[1.02fr,0.98fr] lg:items-start">
      <div class="relative z-[1]">
        <p class="text-xs font-bold uppercase tracking-[0.4em] text-secondary"><%= pageContent.eyebrow %></p>
        <h1 class="mt-6 max-w-5xl font-display text-5xl font-bold leading-[0.98] md:text-6xl lg:text-7xl"><%= pageContent.title %></h1>
        <p class="mt-6 max-w-3xl text-lg leading-8 text-white/76"><%= pageContent.intro %></p>
        <div class="mt-10 flex flex-wrap gap-4">
          <a href="/about-us" class="rounded-full bg-secondary px-6 py-3 text-sm font-bold text-primary shadow-lg shadow-secondary/20">About Kuwexa</a>
          <a href="/contact" class="rounded-full border border-white/16 px-6 py-3 text-sm font-semibold text-white hover:border-secondary hover:text-secondary">Talk to the Team</a>
        </div>
      </div>

      <div class="hero-stage relative z-[1]">
        <div class="hero-stage__frame orbital-pulse" data-reveal>
          <p class="text-xs font-bold uppercase tracking-[0.35em] text-secondary">Leadership Signal</p>
          <div class="hero-stage__grid mt-8">
            <% pageContent.metrics.forEach((item) => { %>
              <article class="hero-stat">
                <p class="hero-stat__value"><%= item.value %></p>
                <p class="hero-stat__label"><%= item.label %></p>
              </article>
            <% }) %>
          </div>
        </div>

        <div class="narrative-card narrative-card--dark reveal" data-reveal>
          <span class="section-kicker !text-white/60 before:!bg-[linear-gradient(90deg,rgba(241,178,74,0.9),rgba(241,178,74,0))]">How the Team Shows Up</span>
          <div class="mt-6 grid gap-4">
            <% pageContent.values.forEach((item) => { %>
              <article class="rounded-[1.45rem] border border-white/10 bg-white/6 p-5">
                <h2 class="font-display text-2xl font-bold text-white"><%= item.title %></h2>
                <p class="mt-3 text-sm leading-7 text-white/72"><%= item.copy %></p>
              </article>
            <% }) %>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="mx-auto max-w-7xl px-6 py-20 lg:px-8">
  <div class="grid gap-6 md:grid-cols-3">
    <% pageContent.values.forEach((item) => { %>
      <article class="narrative-card reveal" data-reveal>
        <span class="section-kicker">Team Value</span>
        <h2 class="mt-5 font-display text-3xl font-bold text-primary"><%= item.title %></h2>
        <p class="mt-4 text-sm leading-8 text-slate-600"><%= item.copy %></p>
      </article>
    <% }) %>
  </div>
</section>

<%- include('../components/team-showcase', {
  eyebrow: 'Leadership and Team',
  title: 'Meet the people guiding and delivering across the Kuwexa ecosystem.',
  copy: 'Each public profile is connected to the dashboard, so images, designations, social links, alt text, and full bios stay editable without losing the visual presentation.'
}) %>

<%- include('../components/site-cta', {
  eyebrow: 'Work With Kuwexa',
  title: 'Need a team that can carry strategy into dependable execution?',
  copy: 'Kuwexa supports businesses with leadership visibility, hands-on delivery, and the operational systems needed to keep digital growth sustainable over time.',
  primaryLabel: 'Contact the Team',
  primaryHref: '/contact',
  secondaryLabel: 'About Kuwexa',
  secondaryHref: '/about-us'
}) %>

<%- include('../layouts/footer') %>
<%- include('../layouts/scripts') %>
