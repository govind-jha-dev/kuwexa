<%- include('../layouts/head', { title, seo }) %>
<section class="flex min-h-screen items-center justify-center px-6 py-16">
  <div class="grid w-full max-w-6xl overflow-hidden rounded-[2.4rem] bg-white shadow-float ring-1 ring-primary/8 lg:grid-cols-[1.05fr,0.95fr]">
    <div class="hero-grid bg-primary p-10 text-white lg:p-12">
      <p class="text-xs font-bold uppercase tracking-[0.35em] text-secondary">Secure Access</p>
      <h1 class="mt-6 max-w-xl font-display text-5xl font-bold leading-tight">Management access for the CodexWebz platform.</h1>
      <p class="mt-5 max-w-lg text-lg leading-8 text-white/72">Admins and managers get role-based access to website settings, content modules, leads, careers, SEO, and analytics.</p>
      <div class="mt-10 rounded-[1.8rem] border border-white/10 bg-white/6 p-6">
        <p class="text-xs font-bold uppercase tracking-[0.3em] text-secondary">Seeded Accounts</p>
        <div class="mt-4 space-y-3 text-sm leading-7 text-white/72">
          <p><code>admin@codexwebz.com</code> / <code>ChangeMe123!</code></p>
          <p><code>manager@codexwebz.com</code> / <code>ChangeMe123!</code></p>
          <p><code>editor@codexwebz.com</code> / <code>ChangeMe123!</code></p>
        </div>
      </div>
    </div>

    <div class="p-10 lg:p-12">
      <a href="/" class="text-sm font-bold text-primary underline decoration-secondary underline-offset-4">Back to website</a>
      <h2 class="mt-6 font-display text-4xl font-bold text-primary">Sign in</h2>
      <p class="mt-3 text-sm leading-7 text-slate-600">JWT authentication, rate limiting, CSRF protection, bcrypt password hashing, and RBAC are all active in this platform.</p>
      <% if (error) { %>
        <div class="mt-6 rounded-[1.5rem] bg-rose-50 px-5 py-4 text-sm font-semibold text-rose-700"><%= error %></div>
      <% } %>
      <form method="post" action="/login" class="mt-8 space-y-4">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div>
          <label class="mb-2 block text-sm font-semibold text-slate-700" for="email">Email</label>
          <input id="email" name="email" type="email" required class="w-full rounded-[1.35rem] border border-primary/10 bg-white px-4 py-3 text-sm focus:border-secondary focus:outline-none">
        </div>
        <div>
          <label class="mb-2 block text-sm font-semibold text-slate-700" for="password">Password</label>
          <input id="password" name="password" type="password" required class="w-full rounded-[1.35rem] border border-primary/10 bg-white px-4 py-3 text-sm focus:border-secondary focus:outline-none">
        </div>
        <button type="submit" class="w-full rounded-[1.35rem] bg-primary px-5 py-3 text-sm font-bold text-white">Login</button>
      </form>
    </div>
  </div>
</section>
<%- include('../components/chat-widget') %>
<%- include('../layouts/scripts') %>
