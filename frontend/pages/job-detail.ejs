<%- include('../layouts/head', { title, seo }) %>
<%- include('../layouts/header') %>

<section class="mx-auto max-w-7xl px-6 py-20 lg:px-8">
  <a href="/careers" class="text-sm font-bold text-primary underline decoration-secondary underline-offset-4">Back to careers</a>
  <div class="mt-8 editorial-grid gap-10">
    <article class="surface-panel rounded-[2.25rem] p-8 lg:p-10">
      <div class="flex flex-wrap items-center gap-3">
        <span class="rounded-full bg-secondary/15 px-4 py-2 text-xs font-bold uppercase tracking-[0.2em] text-primary"><%= job.location || 'Remote' %></span>
        <span class="rounded-full bg-primary/8 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-primary/58"><%= job.employment_type || 'Full-time' %></span>
        <span class="rounded-full bg-emerald-50 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-emerald-700"><%= job.status %></span>
      </div>
      <h1 class="mt-6 font-display text-5xl font-bold leading-tight text-primary md:text-6xl"><%= job.title %></h1>
      <p class="mt-5 max-w-3xl text-lg leading-8 text-slate-600">This role is managed through the CodexWebz careers system, including resume upload, review workflow, and candidate status updates.</p>
      <div class="prose-content mt-10"><%- job.description %></div>
    </article>

    <aside class="space-y-6">
      <div class="rounded-[2rem] bg-primary p-8 text-white">
        <p class="text-xs font-bold uppercase tracking-[0.35em] text-secondary">Apply Now</p>
        <h2 class="mt-4 font-display text-3xl font-bold">Candidate information flows straight into the dashboard.</h2>
        <p class="mt-4 text-sm leading-8 text-white/72">The frontend form here connects to resume upload, application records, and manager review tools in the backend.</p>
      </div>

      <div class="surface-panel rounded-[2rem] p-7">
        <p class="text-xs font-bold uppercase tracking-[0.35em] text-primary/38">Hiring Sequence</p>
        <div class="mt-5 space-y-3">
          <% pageContent.steps.forEach((step, index) => { %>
            <div class="rounded-[1.35rem] bg-slate-50 px-4 py-4 text-sm font-semibold text-slate-700"><%= `0${index + 1}` %> • <%= step %></div>
          <% }) %>
        </div>
      </div>
    </aside>
  </div>

  <div class="mt-12 rounded-[2.2rem] bg-primary p-8 text-white lg:p-10">
    <div class="grid gap-10 lg:grid-cols-[0.85fr,1.15fr]">
      <div>
        <p class="text-xs font-bold uppercase tracking-[0.35em] text-secondary">Application Form</p>
        <h2 class="mt-4 font-display text-4xl font-bold">Submit your application.</h2>
        <% if (applied) { %>
          <div class="mt-6 rounded-[1.5rem] bg-emerald-100 px-5 py-4 text-sm font-semibold text-emerald-700"><%= applied %></div>
        <% } %>
      </div>
      <form method="post" action="/careers/<%= job.slug %>/apply" enctype="multipart/form-data" class="grid gap-4 md:grid-cols-2">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="md:col-span-1">
          <label class="mb-2 block text-sm font-semibold" for="name">Full Name</label>
          <input id="name" name="name" type="text" required class="w-full rounded-[1.35rem] border border-white/10 bg-white/10 px-4 py-3 text-sm text-white placeholder:text-white/38 focus:border-secondary focus:outline-none">
        </div>
        <div class="md:col-span-1">
          <label class="mb-2 block text-sm font-semibold" for="email">Email</label>
          <input id="email" name="email" type="email" required class="w-full rounded-[1.35rem] border border-white/10 bg-white/10 px-4 py-3 text-sm text-white placeholder:text-white/38 focus:border-secondary focus:outline-none">
        </div>
        <div class="md:col-span-1">
          <label class="mb-2 block text-sm font-semibold" for="phone">Phone</label>
          <input id="phone" name="phone" type="text" class="w-full rounded-[1.35rem] border border-white/10 bg-white/10 px-4 py-3 text-sm text-white placeholder:text-white/38 focus:border-secondary focus:outline-none">
        </div>
        <div class="md:col-span-1">
          <label class="mb-2 block text-sm font-semibold" for="resume">Resume</label>
          <input id="resume" name="resume" type="file" required class="w-full rounded-[1.35rem] border border-dashed border-white/20 bg-white/10 px-4 py-3 text-sm file:mr-4 file:rounded-full file:border-0 file:bg-secondary file:px-4 file:py-2 file:font-semibold file:text-primary">
        </div>
        <div class="md:col-span-2">
          <label class="mb-2 block text-sm font-semibold" for="cover_letter">Cover Letter</label>
          <textarea id="cover_letter" name="cover_letter" rows="6" class="w-full rounded-[1.35rem] border border-white/10 bg-white/10 px-4 py-3 text-sm text-white placeholder:text-white/38 focus:border-secondary focus:outline-none"></textarea>
        </div>
        <div class="md:col-span-2">
          <button type="submit" class="w-full rounded-[1.35rem] bg-secondary px-5 py-3 text-sm font-bold text-primary">Submit Application</button>
        </div>
      </form>
    </div>
  </div>
</section>

<%- include('../components/team-showcase', {
  eyebrow: 'Work With',
  title: 'See the leadership and team behind the role.',
  copy: 'The careers flow is operational, but candidates also need clarity on the people and leadership structure they would join.'
}) %>

<%- include('../layouts/footer') %>
<%- include('../layouts/scripts') %>
