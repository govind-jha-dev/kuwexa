<%- include('../layouts/head', { title, seo }) %>
<%- include('../layouts/header') %>

<section class="mx-auto max-w-7xl px-6 py-20 lg:px-8">
  <a href="/portfolio" class="text-sm font-bold text-primary underline decoration-secondary underline-offset-4">Back to portfolio</a>
  <div class="mt-8 editorial-grid gap-10">
    <article class="surface-panel rounded-[2.25rem] p-8 lg:p-10">
      <div class="flex flex-wrap items-center gap-3">
        <span class="rounded-full bg-secondary/15 px-4 py-2 text-xs font-bold uppercase tracking-[0.2em] text-primary"><%= project.category || 'Project' %></span>
        <span class="rounded-full bg-primary/8 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-primary/58"><%= project.client || 'CodexWebz' %></span>
      </div>
      <h1 class="mt-6 font-display text-5xl font-bold leading-tight text-primary md:text-6xl"><%= project.title %></h1>
      <p class="mt-5 max-w-3xl text-lg leading-8 text-slate-600"><%= project.summary %></p>
      <div class="prose-content mt-10"><%- project.description || '<p>This project showcases how frontend quality and backend structure were delivered together.</p>' %></div>
    </article>

    <aside class="space-y-6">
      <% if (project.featured_image) { %>
        <img src="<%= project.featured_image %>" alt="<%= project.title %>" class="h-80 w-full rounded-[2rem] object-cover shadow-float">
      <% } %>
      <div class="rounded-[2rem] bg-primary p-8 text-white">
        <p class="text-xs font-bold uppercase tracking-[0.35em] text-secondary">Project Angle</p>
        <h2 class="mt-4 font-display text-3xl font-bold">Delivery built around credibility and control.</h2>
        <p class="mt-4 text-sm leading-8 text-white/72">This case study highlights how the frontend experience and internal workflow design support each other instead of competing.</p>
      </div>
      <div class="surface-panel rounded-[2rem] p-7">
        <p class="text-xs font-bold uppercase tracking-[0.35em] text-primary/38">Technology Stack</p>
        <div class="mt-5 flex flex-wrap gap-3">
          <% (project.technologies || []).forEach((tech) => { %>
            <span class="rounded-full bg-slate-100 px-4 py-2 text-sm font-semibold text-slate-700"><%= tech %></span>
          <% }) %>
          <% if (!(project.technologies || []).length) { %>
            <span class="text-sm text-slate-500">Technology stack not listed.</span>
          <% } %>
        </div>
      </div>
    </aside>
  </div>

  <% if (project.results) { %>
    <div class="mt-12 rounded-[2.2rem] bg-white p-8 shadow-sm ring-1 ring-primary/8 lg:p-10">
      <%- include('../components/section-heading', {
        eyebrow: 'Results',
        title: 'What the system improved.',
        copy: 'Portfolio should show what changed in the business or workflow, not just what the interface looked like.'
      }) %>
      <div class="prose-content mt-8"><%- project.results %></div>
    </div>
  <% } %>

  <% if ((project.images || []).length) { %>
    <div class="mt-12">
      <%- include('../components/section-heading', {
        eyebrow: 'Gallery',
        title: 'Additional project views.',
        copy: 'Visual assets uploaded through the portfolio module remain reusable in future marketing and proposal work.'
      }) %>
      <div class="mt-8 grid gap-6 md:grid-cols-2">
        <% project.images.forEach((image) => { %>
          <img src="<%= image %>" alt="<%= project.title %>" class="reveal h-72 w-full rounded-[1.85rem] object-cover shadow-sm" data-reveal>
        <% }) %>
      </div>
    </div>
  <% } %>
</section>

<%- include('../components/team-showcase', {
  eyebrow: 'Project Team',
  title: 'Leadership and delivery roles behind work like this.',
  copy: 'The public result looks polished because the execution team, project structure, and operational process stay tightly connected.'
}) %>

<%- include('../components/site-cta', {
  eyebrow: 'Your Next Build',
  title: 'Want a portfolio piece like this that also leaves your team with a usable backend?',
  copy: 'CodexWebz can scope the public site, management system, and content architecture as one project.',
  primaryLabel: 'Start a Project',
  primaryHref: '/contact',
  secondaryLabel: 'More Case Studies',
  secondaryHref: '/portfolio'
}) %>

<%- include('../layouts/footer') %>
<%- include('../layouts/scripts') %>
