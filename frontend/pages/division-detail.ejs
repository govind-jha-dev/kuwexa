<%- include('../layouts/head', { title, seo }) %>
<%- include('../layouts/header') %>

<section class="mx-auto max-w-7xl px-6 py-20 lg:px-8">
  <a href="/divisions" class="text-sm font-bold text-primary underline decoration-secondary underline-offset-4">Back to divisions</a>

  <div class="mt-8 grid gap-6 xl:grid-cols-[1.08fr,0.92fr]">
    <article class="rounded-[2.4rem] border border-primary/10 bg-primary px-8 py-10 text-white shadow-float lg:px-10">
      <p class="text-xs font-bold uppercase tracking-[0.35em] text-secondary"><%= division.label %></p>
      <h1 class="mt-5 max-w-4xl font-display text-5xl font-bold leading-[1.02] md:text-6xl"><%= division.name %></h1>
      <p class="mt-6 max-w-3xl text-lg leading-8 text-white/78"><%= division.shortDescription %></p>
      <p class="mt-5 max-w-3xl text-sm leading-8 text-white/72"><%= division.ecosystemRole %></p>

      <div class="mt-8 grid gap-4 md:grid-cols-3">
        <% division.highlightStats.forEach((item) => { %>
          <article class="rounded-[1.6rem] border border-white/12 bg-white/6 p-5">
            <p class="font-display text-3xl font-bold text-secondary"><%= item.value %></p>
            <p class="mt-3 text-xs font-bold uppercase tracking-[0.22em] text-white/62"><%= item.label %></p>
          </article>
        <% }) %>
      </div>

      <div class="mt-8 rounded-[1.8rem] border border-white/12 bg-white/6 p-6">
        <p class="text-sm leading-8 text-white/78"><%= division.detailNarrative %></p>
      </div>
    </article>

    <aside class="grid gap-6">
      <div class="surface-panel rounded-[2.2rem] p-7">
        <p class="text-xs font-bold uppercase tracking-[0.35em] text-primary/38">Dedicated Destination</p>
        <h2 class="mt-4 font-display text-3xl font-bold text-primary"><%= division.destinationHost %></h2>
        <p class="mt-4 text-sm leading-8 text-slate-600">
          This division can grow through its own destination while staying connected to the overall Kuwexa parent-company story.
        </p>
        <div class="mt-6 flex flex-wrap gap-3">
          <% if (division.destinationUrl.startsWith('http')) { %>
            <a href="<%= division.destinationUrl %>" target="_blank" rel="noreferrer" class="rounded-full bg-primary px-5 py-3 text-sm font-bold text-white"><%= division.destinationLabel %></a>
          <% } else { %>
            <a href="<%= division.destinationUrl %>" class="rounded-full bg-primary px-5 py-3 text-sm font-bold text-white"><%= division.destinationLabel %></a>
          <% } %>
          <a href="/contact" class="rounded-full border border-primary/12 px-5 py-3 text-sm font-semibold text-primary">Contact Kuwexa</a>
        </div>
      </div>

      <div class="surface-panel rounded-[2.2rem] p-7">
        <p class="text-xs font-bold uppercase tracking-[0.35em] text-primary/38">Best For</p>
        <div class="mt-5 flex flex-wrap gap-3">
          <% division.audiences.forEach((item) => { %>
            <span class="rounded-full bg-slate-100 px-4 py-2 text-sm font-semibold text-slate-700"><%= item %></span>
          <% }) %>
        </div>
      </div>

      <div class="surface-panel rounded-[2.2rem] p-7">
        <p class="text-xs font-bold uppercase tracking-[0.35em] text-primary/38">Market Focus</p>
        <div class="mt-5 grid gap-3">
          <% (division.marketFocus || []).forEach((item) => { %>
            <div class="rounded-[1.2rem] bg-slate-50 px-4 py-4 text-sm font-semibold text-slate-700 ring-1 ring-primary/6"><%= item %></div>
          <% }) %>
        </div>
      </div>
    </aside>
  </div>
</section>

<section class="mx-auto max-w-7xl px-6 pb-20 lg:px-8">
  <div class="grid gap-6 xl:grid-cols-[0.94fr,1.06fr]">
    <div class="narrative-card reveal" data-reveal>
      <%- include('../components/section-heading', {
        eyebrow: 'Division Position',
        title: `How ${division.name} fits inside the Kuwexa organization.`,
        copy: 'Each division has a distinct public role, a clearer market focus, and a more useful relationship to the parent-company narrative.'
      }) %>
      <div class="mt-8 grid gap-4">
        <% division.primaryPoints.forEach((item, index) => { %>
          <article class="rounded-[1.55rem] border border-primary/8 bg-white px-5 py-5">
            <p class="text-xs font-bold uppercase tracking-[0.2em] text-secondary">Focus <%= String(index + 1).padStart(2, '0') %></p>
            <p class="mt-3 text-sm font-semibold leading-7 text-slate-700"><%= item %></p>
          </article>
        <% }) %>
      </div>
    </div>

    <div class="narrative-card narrative-card--dark reveal" data-reveal>
      <span class="section-kicker !text-white/60 before:!bg-secondary">Operating Model</span>
      <div class="mt-8 grid gap-4">
        <% division.operatingModel.forEach((item) => { %>
          <article class="rounded-[1.55rem] border border-white/10 bg-white/6 p-5">
            <p class="text-sm leading-8 text-white/78"><%= item %></p>
          </article>
        <% }) %>
      </div>
    </div>
  </div>
</section>

<section class="mx-auto max-w-7xl px-6 pb-20 lg:px-8">
  <div class="grid gap-6 xl:grid-cols-[0.94fr,1.06fr]">
    <div class="narrative-card reveal" data-reveal>
      <%- include('../components/section-heading', {
        eyebrow: 'Signature Areas',
        title: `What ${division.name} is built to deliver.`,
        copy: 'These are the main focus areas that give the division its shape and make the offer feel distinct.'
      }) %>
      <div class="mt-8 grid gap-4">
        <% division.signatureAreas.forEach((item, index) => { %>
          <article class="rounded-[1.55rem] border border-primary/8 bg-white px-5 py-5">
            <p class="text-xs font-bold uppercase tracking-[0.2em] text-secondary">Area <%= String(index + 1).padStart(2, '0') %></p>
            <p class="mt-3 text-sm font-semibold leading-7 text-slate-700"><%= item %></p>
          </article>
        <% }) %>
      </div>
    </div>

    <div class="narrative-card narrative-card--dark reveal" data-reveal>
      <span class="section-kicker !text-white/60 before:!bg-secondary">Experience Pillars</span>
      <div class="mt-8 grid gap-4">
        <% division.experiencePillars.forEach((item) => { %>
          <article class="rounded-[1.55rem] border border-white/10 bg-white/6 p-5">
            <h3 class="font-display text-3xl font-bold text-white"><%= item.title %></h3>
            <p class="mt-3 text-sm leading-8 text-white/74"><%= item.copy %></p>
          </article>
        <% }) %>
      </div>
    </div>
  </div>
</section>

<section class="mx-auto max-w-7xl px-6 pb-20 lg:px-8">
  <div class="narrative-card reveal" data-reveal>
    <%- include('../components/section-heading', {
      eyebrow: 'Operating Rhythm',
      title: `How ${division.name} moves from idea to execution.`,
      copy: 'This is the working rhythm behind the division, from the first framing step to the public or operational result.'
    }) %>
    <div class="mt-10 grid gap-5 lg:grid-cols-3">
      <% division.journeySteps.forEach((item) => { %>
        <article class="rounded-[1.75rem] bg-white p-6 ring-1 ring-primary/8">
          <span class="inline-flex h-12 w-12 items-center justify-center rounded-[1rem] bg-secondary font-display text-xl font-bold text-primary"><%= item.step %></span>
          <h3 class="mt-5 font-display text-3xl font-bold text-primary"><%= item.title %></h3>
          <p class="mt-4 text-sm leading-8 text-slate-600"><%= item.copy %></p>
        </article>
      <% }) %>
    </div>
  </div>
</section>

<%- include('../components/site-cta', {
  eyebrow: 'Need The Right Entry Point?',
  title: `Want to move from the ${division.name} overview into a conversation?`,
  copy: 'Use the division destination for the focused public experience or contact Kuwexa for company-level support and introductions.',
  primaryLabel: division.destinationLabel,
  primaryHref: division.destinationUrl,
  secondaryLabel: 'Contact Kuwexa',
  secondaryHref: '/contact'
}) %>

<%- include('../layouts/footer') %>
<%- include('../layouts/scripts') %>
