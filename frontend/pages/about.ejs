<%- include('../layouts/head', { title, seo }) %>
<%- include('../layouts/header') %>

<section class="kuwexa-hero text-white">
  <div class="mx-auto max-w-7xl px-6 py-20 lg:px-8 lg:py-28">
    <div class="grid gap-12 lg:grid-cols-[1.02fr,0.98fr] lg:items-start">
      <div class="relative z-[1]">
        <p class="text-xs font-bold uppercase tracking-[0.4em] text-secondary"><%= pageContent.eyebrow %></p>
        <h1 class="mt-6 max-w-5xl font-display text-5xl font-bold leading-[0.98] md:text-6xl lg:text-7xl"><%= pageContent.title %></h1>
        <p class="mt-6 max-w-3xl text-lg leading-8 text-white/76"><%= pageContent.intro %></p>
        <p class="mt-5 max-w-3xl text-base leading-8 text-white/66"><%= pageContent.overview || pageContent.summary %></p>
        <div class="mt-10 flex flex-wrap gap-4">
          <a href="/contact" class="rounded-full bg-secondary px-6 py-3 text-sm font-bold text-primary shadow-lg shadow-secondary/20">Talk to Kuwexa</a>
          <a href="#team" class="rounded-full border border-white/16 px-6 py-3 text-sm font-semibold text-white hover:border-secondary hover:text-secondary">Meet the Leadership</a>
        </div>
      </div>

      <div class="hero-stage relative z-[1]">
        <div class="hero-stage__frame orbital-pulse" data-reveal>
          <p class="text-xs font-bold uppercase tracking-[0.35em] text-secondary">Who Kuwexa Supports</p>
          <div class="mt-6 grid gap-4">
            <% pageContent.audience.forEach((item) => { %>
              <article class="rounded-[1.45rem] border border-white/10 bg-white/10 p-5">
                <p class="text-sm font-semibold leading-7 text-white/82"><%= item %></p>
              </article>
            <% }) %>
          </div>
        </div>

        <div class="narrative-card narrative-card--dark reveal" data-reveal>
          <span class="section-kicker !text-white/60 before:!bg-[linear-gradient(90deg,rgba(241,178,74,0.9),rgba(241,178,74,0))]">What Makes It Different</span>
          <div class="mt-6 grid gap-4">
            <% pageContent.highlights.forEach((item) => { %>
              <article class="rounded-[1.45rem] border border-white/10 bg-white/6 p-5">
                <h2 class="font-display text-2xl font-bold text-white"><%= item.title %></h2>
                <p class="mt-3 text-sm leading-7 text-white/72"><%= item.copy %></p>
              </article>
            <% }) %>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="mx-auto max-w-7xl px-6 py-20 lg:px-8">
  <div class="grid gap-6 xl:grid-cols-[1fr,1fr]">
    <div class="narrative-card reveal" data-reveal>
      <span class="section-kicker">Vision</span>
      <h2 class="mt-5 font-display text-4xl font-bold leading-tight text-primary">A globally trusted ecosystem where commerce and technology reinforce one another.</h2>
      <p class="mt-5 text-base leading-8 text-slate-600"><%= pageContent.vision %></p>
      <div class="mt-8 grid gap-4">
        <% (pageContent.visionPoints || []).forEach((item) => { %>
          <article class="rounded-[1.45rem] bg-slate-50 p-4 ring-1 ring-primary/6">
            <p class="text-sm leading-7 text-slate-700"><%= item %></p>
          </article>
        <% }) %>
      </div>
    </div>

    <div class="narrative-card narrative-card--dark reveal" data-reveal>
      <span class="section-kicker !text-white/60 before:!bg-[linear-gradient(90deg,rgba(241,178,74,0.9),rgba(241,178,74,0))]">Mission</span>
      <h2 class="mt-5 font-display text-4xl font-bold leading-tight text-white">Dependable trade and digital systems that help businesses scale with more confidence.</h2>
      <p class="mt-5 text-base leading-8 text-white/72"><%= pageContent.mission %></p>
      <div class="mt-8 grid gap-4">
        <% pageContent.focusAreas.forEach((item) => { %>
          <article class="rounded-[1.45rem] border border-white/10 bg-white/6 p-4 text-sm leading-7 text-white/72"><%= item %></article>
        <% }) %>
      </div>
    </div>
  </div>
</section>

<section class="mx-auto max-w-7xl px-6 pb-20 lg:px-8">
  <div class="grid gap-6 xl:grid-cols-[1.02fr,0.98fr]">
    <div class="narrative-card reveal" data-reveal>
      <span class="section-kicker">Narrative</span>
      <div class="mt-6 space-y-5">
        <% pageContent.narrative.forEach((item) => { %>
          <p class="text-base leading-8 text-slate-600"><%= item %></p>
        <% }) %>
      </div>
    </div>

    <div class="narrative-card reveal" data-reveal>
      <span class="section-kicker">Core Principles</span>
      <div class="mt-6 grid gap-4">
        <% pageContent.principles.forEach((item) => { %>
          <article class="rounded-[1.5rem] bg-slate-50 p-5 ring-1 ring-primary/6">
            <h2 class="font-display text-2xl font-bold text-primary"><%= item.title %></h2>
            <p class="mt-3 text-sm leading-7 text-slate-600"><%= item.copy %></p>
          </article>
        <% }) %>
      </div>
    </div>
  </div>
</section>

<section class="mx-auto max-w-7xl px-6 pb-20 lg:px-8">
  <div class="narrative-card reveal" data-reveal>
    <div class="grid gap-10 xl:grid-cols-[0.9fr,1.1fr]">
      <div>
        <span class="section-kicker">How Kuwexa Works</span>
        <h2 class="mt-5 font-display text-4xl font-bold leading-tight text-primary">A documented operating approach from discovery to steady scale.</h2>
        <p class="mt-5 text-base leading-8 text-slate-600">
          Kuwexa is designed to reduce chaos by making the relationship between commercial goals, technology systems, and day-to-day execution more visible and more manageable.
        </p>
      </div>
      <div class="story-grid">
        <% pageContent.approach.forEach((item, index) => { %>
          <article class="story-step">
            <span class="story-step__index"><%= `0${index + 1}` %></span>
            <h3 class="story-step__title"><%= item.title %></h3>
            <p class="story-step__copy"><%= item.copy %></p>
          </article>
        <% }) %>
      </div>
    </div>
  </div>
</section>

<section class="mx-auto max-w-7xl px-6 pb-20 lg:px-8">
  <div class="grid gap-6 xl:grid-cols-[0.95fr,1.05fr]">
    <div class="narrative-card narrative-card--dark reveal" data-reveal>
      <span class="section-kicker !text-white/60 before:!bg-[linear-gradient(90deg,rgba(241,178,74,0.9),rgba(241,178,74,0))]">Ecosystem Coverage</span>
      <div class="mt-6 flex flex-wrap gap-3">
        <% pageContent.serviceGroups.forEach((item) => { %>
          <span class="signal-chip !bg-white/10 !text-secondary"><%= item %></span>
        <% }) %>
      </div>
    </div>

    <div class="narrative-card reveal" data-reveal>
      <span class="section-kicker">Why Businesses Choose Kuwexa</span>
      <div class="mt-6 grid gap-4">
        <% pageContent.advantages.forEach((item) => { %>
          <article class="rounded-[1.45rem] bg-slate-50 p-4 text-sm leading-7 text-slate-700 ring-1 ring-primary/6"><%= item %></article>
        <% }) %>
      </div>
      <p class="mt-6 text-base leading-8 text-slate-600"><%= pageContent.closing %></p>
    </div>
  </div>
</section>

<div id="team">
  <%- include('../components/team-showcase', {
    eyebrow: 'Leadership and Team',
    title: 'The people shaping the Kuwexa ecosystem.',
    copy: 'Leadership sets the operating direction. The wider team carries that direction into delivery, visibility, technology systems, and long-term support.'
  }) %>
</div>

<%- include('../components/site-cta', {
  eyebrow: 'Build With Kuwexa',
  title: 'Need a partner that can align market reality, digital execution, and long-term operating structure?',
  copy: 'Kuwexa supports businesses through trade capability, digital commerce, websites, platforms, and structured growth systems with a model built for sustainable scale.',
  primaryLabel: 'Start a Conversation',
  primaryHref: '/contact',
  secondaryLabel: 'Explore Capabilities',
  secondaryHref: '/services'
}) %>

<%- include('../layouts/footer') %>
<%- include('../layouts/scripts') %>
