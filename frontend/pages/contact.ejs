<%- include('../layouts/head', { title, seo }) %>
<%- include('../layouts/header') %>

<section class="kuwexa-hero text-white">
  <div class="mx-auto max-w-7xl px-6 py-20 lg:px-8 lg:py-28">
    <div class="grid gap-12 lg:grid-cols-[1.02fr,0.98fr] lg:items-start">
      <div class="relative z-[1]">
        <p class="text-xs font-bold uppercase tracking-[0.4em] text-secondary">Contact</p>
        <h1 class="mt-6 max-w-5xl font-display text-5xl font-bold leading-[0.98] md:text-6xl lg:text-7xl">
          Start a structured conversation with Kuwexa.
        </h1>
        <p class="mt-6 max-w-3xl text-lg leading-8 text-white/76">
          Use this page to discuss trade enablement, digital platforms, websites, SEO systems, operational improvements, or long-term support across the Kuwexa ecosystem.
        </p>
      </div>

      <div class="hero-stage relative z-[1]">
        <div class="hero-stage__frame orbital-pulse" data-reveal>
          <p class="text-xs font-bold uppercase tracking-[0.35em] text-secondary">What Happens Next</p>
          <div class="mt-6 grid gap-3">
            <% pageContent.promises.forEach((item) => { %>
              <div class="rounded-[1.35rem] border border-white/10 bg-white/10 px-4 py-4 text-sm font-semibold text-white/80"><%= item %></div>
            <% }) %>
          </div>
        </div>
      </div>
    </div>

    <div class="mt-12 grid gap-5 md:grid-cols-3">
      <% pageContent.contactCards.forEach((item) => { %>
        <article class="reveal rounded-[1.75rem] border border-white/10 bg-white/8 p-6 backdrop-blur-sm" data-reveal>
          <p class="text-xs font-bold uppercase tracking-[0.22em] text-secondary">Conversation Track</p>
          <h2 class="mt-4 font-display text-2xl font-bold text-white"><%= item.title %></h2>
          <p class="mt-3 text-sm leading-8 text-white/70"><%= item.copy %></p>
        </article>
      <% }) %>
    </div>
  </div>
</section>

<section class="mx-auto max-w-7xl px-6 py-20 lg:px-8">
  <div class="grid gap-6 xl:grid-cols-[0.95fr,1.05fr]">
    <div class="grid gap-6">
      <div class="narrative-card narrative-card--dark reveal" data-reveal>
        <span class="section-kicker !text-white/60 before:!bg-[linear-gradient(90deg,rgba(241,178,74,0.9),rgba(241,178,74,0))]">Contact Channels</span>
        <div class="mt-6 grid gap-4">
          <article class="rounded-[1.45rem] border border-white/10 bg-white/6 p-5">
            <p class="text-xs font-bold uppercase tracking-[0.22em] text-secondary">Email</p>
            <p class="mt-3 text-sm font-semibold text-white/84"><%= siteSettings?.company_email || 'hello@kuwexa.com' %></p>
          </article>
          <article class="rounded-[1.45rem] border border-white/10 bg-white/6 p-5">
            <p class="text-xs font-bold uppercase tracking-[0.22em] text-secondary">Phone</p>
            <p class="mt-3 text-sm font-semibold text-white/84"><%= siteSettings?.company_phone || '+91 00000 00000' %></p>
          </article>
          <article class="rounded-[1.45rem] border border-white/10 bg-white/6 p-5">
            <p class="text-xs font-bold uppercase tracking-[0.22em] text-secondary">Address / Delivery Base</p>
            <p class="mt-3 text-sm font-semibold leading-7 text-white/78"><%= siteSettings?.address || 'Hybrid commerce and digital delivery operations managed with structured follow-up and clear execution paths.' %></p>
          </article>
        </div>
      </div>

      <div class="narrative-card reveal" data-reveal>
        <span class="section-kicker">Engagement Models</span>
        <div class="mt-6 grid gap-4">
          <% pageContent.engagementModels.forEach((item) => { %>
            <article class="rounded-[1.45rem] bg-slate-50 p-5 ring-1 ring-primary/6">
              <h3 class="font-display text-2xl font-bold text-primary"><%= item.title %></h3>
              <p class="mt-3 text-sm leading-7 text-slate-600"><%= item.copy %></p>
            </article>
          <% }) %>
        </div>
      </div>

      <div class="narrative-card reveal" data-reveal>
        <span class="section-kicker">Response Flow</span>
        <div class="story-grid mt-8">
          <% pageContent.responseSteps.forEach((item) => { %>
            <article class="story-step">
              <span class="story-step__index"><%= item.step %></span>
              <h3 class="story-step__title"><%= item.title %></h3>
              <p class="story-step__copy"><%= item.copy %></p>
            </article>
          <% }) %>
        </div>
      </div>
    </div>

    <div class="narrative-card reveal" data-reveal>
      <% if (sent) { %>
        <div class="mb-6 rounded-[1.5rem] bg-emerald-50 px-5 py-4 text-sm font-semibold text-emerald-700"><%= sent %></div>
      <% } %>
      <span class="section-kicker">Inquiry Form</span>
      <h2 class="mt-5 font-display text-4xl font-bold text-primary">Tell us what needs to move.</h2>
      <p class="mt-4 text-base leading-8 text-slate-600">
        Every inquiry creates a structured lead record in the dashboard so follow-up, assignment, and response history stay organized from the beginning.
      </p>

      <form method="post" action="/contact" class="mt-8 space-y-4">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="grid gap-4 md:grid-cols-2">
          <div>
            <label class="mb-2 block text-sm font-semibold text-slate-700" for="name">Name</label>
            <input id="name" name="name" type="text" required class="w-full rounded-[1.35rem] border border-primary/10 bg-white px-4 py-3 text-sm focus:border-secondary focus:outline-none">
          </div>
          <div>
            <label class="mb-2 block text-sm font-semibold text-slate-700" for="email">Email</label>
            <input id="email" name="email" type="email" required class="w-full rounded-[1.35rem] border border-primary/10 bg-white px-4 py-3 text-sm focus:border-secondary focus:outline-none">
          </div>
        </div>
        <div class="grid gap-4 md:grid-cols-[0.9fr,1.1fr]">
          <div>
            <label class="mb-2 block text-sm font-semibold text-slate-700" for="phone">Phone</label>
            <input id="phone" name="phone" type="text" class="w-full rounded-[1.35rem] border border-primary/10 bg-white px-4 py-3 text-sm focus:border-secondary focus:outline-none">
          </div>
          <div>
            <label class="mb-2 block text-sm font-semibold text-slate-700" for="source">Inquiry Type</label>
            <select id="source" name="source" class="w-full rounded-[1.35rem] border border-primary/10 bg-white px-4 py-3 text-sm focus:border-secondary focus:outline-none">
              <option value="Kuwexa Website Inquiry">Hybrid commerce inquiry</option>
              <option value="Trade Enablement">Trade enablement or market access</option>
              <option value="Digital Platform Build">Digital platform or website build</option>
              <option value="SEO and Growth System">SEO, visibility, or content system</option>
              <option value="Long-Term Support">Long-term support and optimization</option>
            </select>
          </div>
        </div>
        <div>
          <label class="mb-2 block text-sm font-semibold text-slate-700" for="message">Brief</label>
          <textarea id="message" name="message" rows="7" required class="w-full rounded-[1.35rem] border border-primary/10 bg-white px-4 py-3 text-sm focus:border-secondary focus:outline-none" placeholder="Share the current challenge, the desired outcome, and what kind of support or system you need."></textarea>
        </div>
        <div class="rounded-[1.45rem] bg-slate-50 p-5 ring-1 ring-primary/6">
          <p class="text-xs font-bold uppercase tracking-[0.22em] text-primary/38">Helpful Details to Include</p>
          <div class="mt-4 grid gap-3">
            <% pageContent.checklist.forEach((item) => { %>
              <div class="rounded-[1.1rem] bg-white px-4 py-3 text-sm font-semibold text-slate-700 ring-1 ring-primary/6"><%= item %></div>
            <% }) %>
          </div>
        </div>
        <button type="submit" class="w-full rounded-[1.35rem] bg-primary px-5 py-3 text-sm font-bold text-white">Send Inquiry</button>
      </form>
    </div>
  </div>
</section>

<section class="mx-auto max-w-7xl px-6 pb-20 lg:px-8">
  <%- include('../components/section-heading', {
    eyebrow: 'FAQ',
    title: 'Questions teams ask before reaching out.',
    copy: 'The goal is to make sure the public experience, SEO structure, and backend workflow all stay aligned from the first conversation.'
  }) %>
  <div class="mt-10">
    <%- include('../components/faq-list', { items: pageContent.faqs }) %>
  </div>
</section>

<%- include('../layouts/footer') %>
<%- include('../layouts/scripts') %>
