<%- include('../layouts/head', { title, seo }) %>
<%- include('../layouts/header') %>

<section class="hero-grid overflow-hidden bg-primary text-white">
  <div class="mx-auto max-w-7xl px-6 py-20 lg:px-8 lg:py-28">
    <div class="grid gap-12 lg:grid-cols-[1.08fr,0.92fr] lg:items-end">
      <div>
        <p class="text-xs font-bold uppercase tracking-[0.4em] text-secondary">CodexWebz Web Platform</p>
        <h1 class="mt-6 max-w-4xl font-display text-5xl font-bold leading-[1.02] md:text-6xl lg:text-7xl">
          Detailed landing pages and operational software in one delivery system.
        </h1>
        <p class="mt-6 max-w-2xl text-lg leading-8 text-white/72">
          CodexWebz builds attractive, high-trust company websites with connected dashboards, SEO controls, lead workflows, hiring workflows, and production-ready backend infrastructure.
        </p>
        <div class="mt-10 flex flex-wrap gap-4">
          <a href="/contact" class="rounded-full bg-secondary px-6 py-3 text-sm font-bold text-primary shadow-lg shadow-secondary/20">Request a Build Plan</a>
          <a href="/portfolio" class="rounded-full border border-white/16 px-6 py-3 text-sm font-semibold text-white hover:border-secondary hover:text-secondary">View Portfolio</a>
        </div>
        <div class="mt-10 flex flex-wrap gap-3">
          <% marketing.capabilityBands.forEach((band) => { %>
            <span class="rounded-full border border-white/12 px-4 py-2 text-xs font-semibold uppercase tracking-[0.22em] text-white/68"><%= band %></span>
          <% }) %>
        </div>
      </div>

      <div class="space-y-5">
        <div class="glass-card rounded-[2rem] p-6 text-slate-900 shadow-float ring-1 ring-white/10">
          <div class="flex items-start justify-between gap-4">
            <div>
              <p class="text-xs font-bold uppercase tracking-[0.35em] text-primary/38">Platform Scope</p>
              <h2 class="mt-3 font-display text-3xl font-bold text-primary">Built for both credibility and control</h2>
            </div>
            <span class="rounded-full bg-secondary px-4 py-2 text-xs font-bold uppercase tracking-[0.18em] text-primary">Live System</span>
          </div>
          <div class="mt-6 space-y-4">
            <% marketing.highlights.forEach((item) => { %>
              <article class="rounded-[1.5rem] border border-primary/8 bg-white/80 p-5">
                <h3 class="font-display text-2xl font-bold text-primary"><%= item.title %></h3>
                <p class="mt-2 text-sm leading-7 text-slate-600"><%= item.copy %></p>
              </article>
            <% }) %>
          </div>
        </div>
        <div class="rounded-[2rem] border border-white/10 bg-white/6 p-6">
          <p class="text-xs font-bold uppercase tracking-[0.35em] text-secondary">Hiring and Growth</p>
          <p class="mt-4 text-base leading-8 text-white/72"><%= marketing.jobsSummary %></p>
        </div>
      </div>
    </div>

    <div class="mt-14 grid gap-4 md:grid-cols-2 xl:grid-cols-4">
      <% marketing.proofStats.forEach((item) => { %>
        <article class="reveal rounded-[1.75rem] border border-white/10 bg-white/6 p-5" data-reveal>
          <p class="font-display text-4xl font-bold text-secondary"><%= item.value %></p>
          <h3 class="mt-3 text-base font-bold"><%= item.label %></h3>
          <p class="mt-2 text-sm leading-7 text-white/68"><%= item.copy %></p>
        </article>
      <% }) %>
    </div>
  </div>
</section>

<section class="mx-auto max-w-7xl px-6 py-20 lg:px-8">
  <%- include('../components/section-heading', {
    eyebrow: 'Services',
    title: 'The frontend looks premium because the system behind it is structured.',
    copy: 'Every landing page is backed by a manager-editable service module, media support, SEO controls, and content architecture that is ready for growth.'
  }) %>
  <div class="mt-12 grid gap-6 lg:grid-cols-2">
    <% services.forEach((service) => { %>
      <article class="reveal spotlight-card surface-panel rounded-[2rem] p-7" data-reveal>
        <div class="flex flex-wrap items-center justify-between gap-3">
          <span class="rounded-full bg-secondary/15 px-4 py-2 text-xs font-bold uppercase tracking-[0.2em] text-primary"><%= service.profile.category %></span>
          <span class="text-xs font-semibold uppercase tracking-[0.22em] text-primary/35"><%= service.icon || 'CodexWebz Service' %></span>
        </div>
        <h3 class="mt-5 font-display text-3xl font-bold text-primary"><%= service.title %></h3>
        <p class="mt-4 text-sm leading-8 text-slate-600"><%= service.short_description || service.profile.kicker %></p>
        <div class="mt-6 grid gap-3 sm:grid-cols-2">
          <% service.profile.deliverables.slice(0, 2).forEach((item) => { %>
            <div class="rounded-[1.35rem] bg-slate-50 px-4 py-4 text-sm font-semibold text-slate-700"><%= item %></div>
          <% }) %>
        </div>
        <a href="/services/<%= service.slug %>" class="mt-6 inline-flex items-center gap-2 text-sm font-bold text-primary">
          Explore service
          <span aria-hidden="true">→</span>
        </a>
      </article>
    <% }) %>
  </div>
</section>

<section class="mx-auto max-w-7xl px-6 pb-20 lg:px-8">
  <div class="rounded-[2.25rem] bg-white p-8 shadow-sm ring-1 ring-primary/8 lg:p-10">
    <div class="editorial-grid gap-10">
      <div>
        <%- include('../components/section-heading', {
          eyebrow: 'Workflow',
          title: 'A deliberate delivery sequence from positioning to launch.',
          copy: 'The frontend is attractive because the content system, user roles, and backend workflows are designed at the same time.'
        }) %>
      </div>
      <div class="space-y-4">
        <% marketing.workflow.forEach((item) => { %>
          <article class="reveal rounded-[1.6rem] border border-slate-200 bg-slate-50/80 p-5" data-reveal>
            <div class="flex gap-4">
              <span class="font-display text-3xl font-bold text-secondary"><%= item.step %></span>
              <div>
                <h3 class="font-display text-2xl font-bold text-primary"><%= item.title %></h3>
                <p class="mt-2 text-sm leading-7 text-slate-600"><%= item.copy %></p>
              </div>
            </div>
          </article>
        <% }) %>
      </div>
    </div>
  </div>
</section>

<section class="mx-auto max-w-7xl px-6 pb-20 lg:px-8">
  <div class="grid gap-6 xl:grid-cols-[1.12fr,0.88fr]">
    <div class="rounded-[2.25rem] bg-primary p-8 text-white lg:p-10">
      <p class="text-xs font-bold uppercase tracking-[0.35em] text-secondary">Portfolio</p>
      <h2 class="mt-4 max-w-2xl font-display text-4xl font-bold leading-tight">Proof built into the public experience.</h2>
      <div class="mt-8 space-y-4">
        <% projects.forEach((project) => { %>
          <a href="/portfolio/<%= project.slug %>" class="reveal block rounded-[1.7rem] border border-white/10 bg-white/6 p-5 transition hover:bg-white/10" data-reveal>
            <div class="flex flex-wrap items-center justify-between gap-4">
              <div>
                <h3 class="font-display text-2xl font-bold"><%= project.title %></h3>
                <p class="mt-2 text-sm leading-7 text-white/68"><%= project.summary %></p>
              </div>
              <span class="rounded-full bg-secondary px-4 py-2 text-xs font-bold uppercase tracking-[0.18em] text-primary"><%= project.category || 'Project' %></span>
            </div>
          </a>
        <% }) %>
      </div>
    </div>

    <div class="space-y-6">
      <div class="surface-panel rounded-[2.25rem] p-8">
        <p class="text-xs font-bold uppercase tracking-[0.35em] text-primary/38">Latest Writing</p>
        <div class="mt-6 space-y-5">
          <% posts.forEach((post) => { %>
            <article class="reveal border-b border-slate-200 pb-5 last:border-b-0 last:pb-0" data-reveal>
              <p class="text-xs font-bold uppercase tracking-[0.2em] text-secondary"><%= post.category || 'Article' %></p>
              <h3 class="mt-3 font-display text-2xl font-bold text-primary"><%= post.title %></h3>
              <p class="mt-3 text-sm leading-7 text-slate-600"><%= post.summary %></p>
              <a href="/blog/<%= post.slug %>" class="mt-4 inline-flex items-center gap-2 text-sm font-bold text-primary">Read article <span aria-hidden="true">→</span></a>
            </article>
          <% }) %>
        </div>
      </div>

      <div class="surface-panel rounded-[2.25rem] p-8">
        <p class="text-xs font-bold uppercase tracking-[0.35em] text-primary/38">What clients notice</p>
        <div class="mt-6 grid gap-4">
          <% marketing.testimonials.forEach((item) => { %>
            <article class="reveal rounded-[1.5rem] bg-slate-50 p-5" data-reveal>
              <p class="text-sm leading-8 text-slate-600">“<%= item.quote %>”</p>
              <p class="mt-4 font-display text-xl font-bold text-primary"><%= item.name %></p>
              <p class="text-sm text-slate-500"><%= item.company %></p>
            </article>
          <% }) %>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="mx-auto max-w-7xl px-6 pb-20 lg:px-8">
  <%- include('../components/section-heading', {
    eyebrow: 'FAQ',
    title: 'Common questions before a platform build starts.',
    copy: 'The public frontend, backend architecture, and management modules are designed as one delivery scope, so the questions are usually operational as much as visual.'
  }) %>
  <div class="mt-10">
    <%- include('../components/faq-list', { items: marketing.faqs }) %>
  </div>
</section>

<%- include('../components/site-cta', {
  eyebrow: 'Ready to Build',
  title: 'Want the public website to look polished and the backend to actually run the business logic?',
  copy: 'CodexWebz delivers both. Start with the landing pages and system architecture, then turn the entire platform into an operating asset.',
  primaryLabel: 'Start a Project',
  primaryHref: '/contact',
  secondaryLabel: 'Explore Services',
  secondaryHref: '/services'
}) %>

<%- include('../layouts/footer') %>
<%- include('../layouts/scripts') %>
