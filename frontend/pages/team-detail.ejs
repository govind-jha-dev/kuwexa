<%- include('../layouts/head', { title, seo }) %>
<%- include('../layouts/header') %>
<%
  const dashboardManagedNotice = 'Full profile content is managed from the Team dashboard, including biography, social links, and media.';
  const fallbackShortBio = member.short_bio && member.short_bio !== dashboardManagedNotice ? member.short_bio : '';
  const baseProfileHtml = member.bio || (fallbackShortBio ? `<p>${fallbackShortBio}</p>` : '');
  const escapedDashboardManagedNotice = dashboardManagedNotice.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
  const cleanedProfileHtml = String(baseProfileHtml || '')
    .replace(new RegExp(`<p>\\s*${escapedDashboardManagedNotice}\\s*<\\/p>`, 'gi'), '')
    .replace(new RegExp(escapedDashboardManagedNotice, 'gi'), '')
    .trim();
  const profileHtml = cleanedProfileHtml || (fallbackShortBio ? `<p>${fallbackShortBio}</p>` : '<p>Profile information will appear here soon.</p>');
%>

<section class="mx-auto max-w-7xl px-6 py-20 lg:px-8">
  <a href="/about-us#team" class="text-sm font-bold text-primary underline decoration-secondary underline-offset-4">Back to About Us</a>

  <div class="mt-8 grid gap-8 xl:grid-cols-[0.86fr,1.14fr]">
    <aside class="space-y-6">
      <div class="overflow-hidden rounded-[2.2rem] bg-primary text-white shadow-float">
        <% if (member.image) { %>
          <img src="<%= member.image %>" alt="<%= member.name %>" class="h-[28rem] w-full object-cover" decoding="async" fetchpriority="high">
        <% } else { %>
          <div class="flex h-[28rem] items-center justify-center bg-[radial-gradient(circle_at_top,_rgba(219,171,13,0.24),_transparent_40%),linear-gradient(180deg,_rgba(255,255,255,0.08),_rgba(255,255,255,0.02))]">
            <div class="flex h-28 w-28 items-center justify-center rounded-[2rem] bg-secondary text-4xl font-bold text-primary">
              <%= String(member.name || 'CW').split(/\s+/).filter(Boolean).map((part) => part.charAt(0)).join('').slice(0, 2).toUpperCase() %>
            </div>
          </div>
        <% } %>
      </div>

      <div class="rounded-[2rem] bg-primary p-7 text-white">
        <p class="text-xs font-bold uppercase tracking-[0.35em] text-secondary"><%= member.department || (member.member_type === 'leadership' ? 'Leadership' : 'Team') %></p>
        <h1 class="mt-4 font-display text-4xl font-bold"><%= member.name %></h1>
        <p class="mt-3 text-sm font-semibold uppercase tracking-[0.22em] text-white/72"><%= member.designation %></p>
        <% if (member.short_bio) { %>
          <p class="mt-5 text-sm leading-8 text-white/72"><%= member.short_bio %></p>
        <% } %>
      </div>
    </aside>

    <article class="surface-panel rounded-[2.2rem] p-8 lg:p-10">
      <div class="flex flex-wrap gap-3">
        <% if (member.email) { %>
          <a href="mailto:<%= member.email %>" class="rounded-full border border-primary/10 px-4 py-2 text-xs font-semibold uppercase tracking-[0.18em] text-primary/72 hover:border-secondary hover:text-primary">Email</a>
        <% } %>
        <% if (member.phone) { %>
          <a href="tel:<%= String(member.phone).replace(/\s+/g, '') %>" class="rounded-full border border-primary/10 px-4 py-2 text-xs font-semibold uppercase tracking-[0.18em] text-primary/72 hover:border-secondary hover:text-primary">Call</a>
        <% } %>
        <% if (member.linkedin_url) { %>
          <a href="<%= member.linkedin_url %>" class="rounded-full border border-primary/10 px-4 py-2 text-xs font-semibold uppercase tracking-[0.18em] text-primary/72 hover:border-secondary hover:text-primary" target="_blank" rel="noreferrer">LinkedIn</a>
        <% } %>
        <% if (member.twitter_url) { %>
          <a href="<%= member.twitter_url %>" class="rounded-full border border-primary/10 px-4 py-2 text-xs font-semibold uppercase tracking-[0.18em] text-primary/72 hover:border-secondary hover:text-primary" target="_blank" rel="noreferrer">Twitter</a>
        <% } %>
        <% if (member.facebook_url) { %>
          <a href="<%= member.facebook_url %>" class="rounded-full border border-primary/10 px-4 py-2 text-xs font-semibold uppercase tracking-[0.18em] text-primary/72 hover:border-secondary hover:text-primary" target="_blank" rel="noreferrer">Facebook</a>
        <% } %>
      </div>

      <div class="mt-8">
        <%- include('../components/section-heading', {
          eyebrow: 'Profile',
          title: `${member.name} at CodexWEBZ`,
        }) %>
      </div>

      <div class="prose-content mt-8">
        <%- profileHtml %>
      </div>
    </article>
  </div>
</section>

<%- include('../components/site-cta', {
  eyebrow: 'Need a Team Like This',
  title: 'Build a company website where team profiles, leadership visibility, and backend editing work together.',
  copy: 'CodexWEBZ can design the public presentation and the management workflow as one dependable platform.',
  primaryLabel: 'Talk to CodexWEBZ',
  primaryHref: '/contact',
  secondaryLabel: 'About Us',
  secondaryHref: '/about-us'
}) %>

<%- include('../layouts/footer') %>
<%- include('../layouts/scripts') %>
