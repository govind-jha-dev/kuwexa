<%- include('../layouts/head', { title, seo }) %>
<%- include('../layouts/header') %>
<section class="mx-auto flex max-w-5xl items-center px-6 py-24 lg:px-8">
  <div class="w-full rounded-[2.25rem] bg-white p-10 text-center shadow-float ring-1 ring-primary/8 lg:p-14">
    <p class="text-xs font-bold uppercase tracking-[0.35em] text-secondary">System Message</p>
    <h1 class="mt-5 font-display text-5xl font-bold text-primary md:text-6xl"><%= title %></h1>
    <p class="mx-auto mt-6 max-w-2xl text-lg leading-8 text-slate-600"><%= message %></p>
    <div class="mt-8 flex justify-center gap-4">
      <a href="/" class="rounded-full bg-primary px-6 py-3 text-sm font-bold text-white">Return Home</a>
      <a href="/contact" class="rounded-full border border-primary/10 px-6 py-3 text-sm font-semibold text-primary">Contact Kuwexa</a>
    </div>
  </div>
</section>
<%- include('../layouts/footer') %>
<%- include('../layouts/scripts') %>
