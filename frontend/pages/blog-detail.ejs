<%- include('../layouts/head', { title, seo }) %>
<%- include('../layouts/header') %>

<article class="mx-auto max-w-6xl px-6 py-20 lg:px-8">
  <a href="/blog" class="text-sm font-bold text-primary underline decoration-secondary underline-offset-4">Back to blog</a>
  <div class="mt-8 editorial-grid gap-10">
    <div class="surface-panel rounded-[2.25rem] p-8 lg:p-10">
      <div class="flex flex-wrap items-center gap-3">
        <span class="rounded-full bg-secondary/15 px-4 py-2 text-xs font-bold uppercase tracking-[0.2em] text-primary"><%= post.category || 'Article' %></span>
        <span class="rounded-full bg-primary/8 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-primary/58"><%= post.author_name || 'Kuwexa Editorial Team' %></span>
      </div>
      <h1 class="mt-6 font-display text-5xl font-bold leading-tight text-primary md:text-6xl"><%= post.title %></h1>
      <p class="mt-5 max-w-3xl text-lg leading-8 text-slate-600"><%= post.summary %></p>
      <div class="mt-6 flex flex-wrap gap-3 text-sm text-slate-500">
        <span><%= new Date(post.published_at || post.created_at).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %></span>
        <% (post.tags || []).slice(0, 4).forEach((tag) => { %>
          <span class="rounded-full bg-slate-100 px-3 py-2 text-xs font-semibold text-slate-600"><%= tag %></span>
        <% }) %>
      </div>
      <% if (post.featured_image) { %>
        <img src="<%= post.featured_image %>" alt="<%= resolveImageAlt(post.featured_image, `${post.title} featured image`) %>" class="mt-8 h-80 w-full rounded-[2rem] object-cover" decoding="async" fetchpriority="high">
      <% } %>
      <div class="prose-content mt-10"><%- post.content || '<p>Article content will appear here soon.</p>' %></div>
    </div>

    <aside class="space-y-6">
      <div class="rounded-[2rem] bg-primary p-8 text-white">
        <p class="text-xs font-bold uppercase tracking-[0.35em] text-secondary">Editorial Perspective</p>
        <h2 class="mt-4 font-display text-3xl font-bold">This article sits inside the wider Kuwexa editorial presence.</h2>
        <p class="mt-4 text-sm leading-8 text-white/72">Each article is written to support credibility, clarity, and long-term search visibility.</p>
      </div>

      <div class="surface-panel rounded-[2rem] p-7">
        <p class="text-xs font-bold uppercase tracking-[0.35em] text-primary/38">Why it matters</p>
        <div class="mt-5 space-y-3 text-sm leading-7 text-slate-600">
          <p>Thoughtful editorial design increases brand trust.</p>
          <p>Clear metadata and structure help the article travel farther.</p>
          <p>Consistent publishing strengthens the organization voice over time.</p>
        </div>
      </div>
    </aside>
  </div>
</article>

<%- include('../components/team-showcase', {
  eyebrow: 'Editorial Team',
  title: 'Meet the leadership and team behind Kuwexa insights.',
  copy: 'The blog reflects the same people who shape company direction, content quality, and public communication.'
}) %>

<%- include('../components/site-cta', {
  eyebrow: 'Build Your Editorial Presence',
  title: 'Need articles, landing pages, and SEO content that stay credible over time?',
  copy: 'Kuwexa can shape an editorial presence that supports trust, visibility, and long-term communication.',
  primaryLabel: 'Talk to Kuwexa',
  primaryHref: '/contact',
  secondaryLabel: 'More Articles',
  secondaryHref: '/blog'
}) %>

<%- include('../layouts/footer') %>
<%- include('../layouts/scripts') %>
