<%- include('../layouts/head', { title, seo }) %>
<%- include('../layouts/header') %>

<section class="mx-auto max-w-7xl px-6 py-20 lg:px-8">
  <a href="/b2b" class="text-sm font-bold text-primary underline decoration-secondary underline-offset-4">Back to B2B catalog</a>

  <div class="mt-8 editorial-grid gap-10">
    <article class="surface-panel rounded-[2.25rem] p-8 lg:p-10">
      <div class="flex flex-wrap items-center gap-4">
        <div class="flex h-20 w-20 items-center justify-center overflow-hidden rounded-[1.4rem] bg-slate-50 ring-1 ring-primary/8">
          <% if (product.logo) { %>
            <img src="<%= product.logo %>" alt="<%= resolveImageAlt(product.logo, `${product.name} logo`) %>" class="h-14 w-14 object-contain" decoding="async">
          <% } else { %>
            <span class="font-display text-3xl font-bold text-primary"><%= String(product.name || 'P').charAt(0) %></span>
          <% } %>
        </div>
        <div>
          <p class="text-xs font-bold uppercase tracking-[0.35em] text-secondary"><%= product.category_name || 'B2B Product' %></p>
          <h1 class="mt-3 font-display text-5xl font-bold leading-tight text-primary md:text-6xl"><%= product.name %></h1>
        </div>
      </div>
      <p class="mt-6 max-w-3xl text-lg leading-8 text-slate-600"><%= product.short_description || 'Detailed product information will appear here.' %></p>
      <div class="prose-content mt-10"><%- product.description || '<p>More product information will be shared here soon.</p>' %></div>
    </article>

    <aside class="space-y-6">
      <% if (product.logo) { %>
        <img src="<%= product.logo %>" alt="<%= resolveImageAlt(product.logo, `${product.name} logo`) %>" class="h-80 w-full rounded-[2rem] object-contain bg-white p-8 shadow-float ring-1 ring-primary/8" decoding="async" fetchpriority="high">
      <% } %>
      <div class="rounded-[2rem] bg-primary p-8 text-white">
        <p class="text-xs font-bold uppercase tracking-[0.35em] text-secondary">Quick Actions</p>
        <h2 class="mt-4 font-display text-3xl font-bold">Need pricing, brochure details, or a quantity quote?</h2>
        <div class="mt-6 flex flex-wrap gap-3">
          <a href="/b2b#enquiry-form" class="rounded-full bg-secondary px-5 py-3 text-sm font-bold text-primary">Send Enquiry</a>
          <% if (product.catalog_link) { %>
            <a href="<%= product.catalog_link %>" target="_blank" rel="noreferrer" class="rounded-full border border-white/12 px-5 py-3 text-sm font-semibold text-white">Open Brochure</a>
          <% } %>
          <% if (product.website_link) { %>
            <a href="<%= product.website_link %>" target="_blank" rel="noreferrer" class="rounded-full border border-white/12 px-5 py-3 text-sm font-semibold text-white">Reference Link</a>
          <% } %>
        </div>
      </div>
      <div class="surface-panel rounded-[2rem] p-7">
        <p class="text-xs font-bold uppercase tracking-[0.35em] text-primary/38">Product Snapshot</p>
        <div class="mt-5 grid gap-3">
          <div class="rounded-[1.2rem] bg-slate-50 px-4 py-4 text-sm font-semibold text-slate-700">Category: <%= product.category_name || 'General' %></div>
          <% if (product.min_order_quantity) { %>
            <div class="rounded-[1.2rem] bg-slate-50 px-4 py-4 text-sm font-semibold text-slate-700">MOQ: <%= product.min_order_quantity %><%= product.unit_label ? ` ${product.unit_label}` : '' %></div>
          <% } %>
          <% if (!(product.min_order_quantity)) { %>
            <div class="rounded-[1.2rem] bg-slate-50 px-4 py-4 text-sm font-semibold text-slate-700">MOQ: Available on enquiry</div>
          <% } %>
        </div>
      </div>
      <div class="surface-panel rounded-[2rem] p-7">
        <p class="text-xs font-bold uppercase tracking-[0.35em] text-primary/38">Applications / Tags</p>
        <div class="mt-5 flex flex-wrap gap-3">
          <% (product.tech_stack || []).forEach((item) => { %>
            <span class="rounded-full bg-slate-100 px-4 py-2 text-sm font-semibold text-slate-700"><%= item %></span>
          <% }) %>
          <% if (!(product.tech_stack || []).length) { %>
            <span class="text-sm text-slate-500">No product applications added yet.</span>
          <% } %>
        </div>
      </div>
    </aside>
  </div>

  <section class="mt-12 rounded-[2.2rem] bg-white p-8 shadow-sm ring-1 ring-primary/8 lg:p-10">
    <%- include('../components/section-heading', {
      eyebrow: 'Highlights',
      title: 'What this product listing communicates.',
      copy: 'Product highlights are presented here so buyers can review the essential details quickly.'
    }) %>
    <div class="mt-8 grid gap-4 md:grid-cols-2">
      <% (product.features || []).forEach((feature) => { %>
        <article class="rounded-[1.6rem] bg-slate-50 px-5 py-5 text-sm font-semibold leading-7 text-slate-700"><%= feature %></article>
      <% }) %>
      <% if (!(product.features || []).length) { %>
        <article class="rounded-[1.6rem] border border-dashed border-primary/20 bg-slate-50 px-5 py-5 text-sm text-slate-500 md:col-span-2">No product highlights added yet.</article>
      <% } %>
    </div>
  </section>

  <% if ((product.images || []).length) { %>
    <section class="mt-12">
      <%- include('../components/section-heading', {
        eyebrow: 'Gallery',
        title: 'Product images and supporting visuals.',
        copy: 'Supporting product visuals appear here when available.'
      }) %>
      <div class="mt-8 grid gap-6 md:grid-cols-2">
        <% product.images.forEach((image) => { %>
          <img src="<%= image %>" alt="<%= resolveImageAlt(image, `${product.name} image`) %>" class="reveal h-72 w-full rounded-[1.85rem] object-cover shadow-sm" data-reveal loading="lazy" decoding="async">
        <% }) %>
      </div>
    </section>
  <% } %>
</section>

<%- include('../components/site-cta', {
  eyebrow: 'Need A Quote?',
  title: 'Want to include this product in a B2B enquiry?',
  copy: 'Go back to the B2B catalog, select one or more products, and send the details in a single enquiry form.',
  primaryLabel: 'Open Enquiry Form',
  primaryHref: '/b2b#enquiry-form',
  secondaryLabel: 'Back to B2B Catalog',
  secondaryHref: '/b2b'
}) %>

<%- include('../layouts/footer') %>
<%- include('../layouts/scripts') %>
