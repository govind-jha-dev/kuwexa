<%- include('../layouts/head', { title, seo }) %>
<%- include('../layouts/header') %>

<section class="mx-auto max-w-7xl px-6 py-20 lg:px-8">
  <div class="grid gap-10 lg:grid-cols-[1fr,0.88fr] lg:items-end">
    <%- include('../components/section-heading', {
      eyebrow: 'Blog',
      title: 'Detailed frontend and backend thinking from the implementation side.',
      copy: 'Articles here are meant to support positioning, SEO, and trust while showing how the platform is structured in practice.'
    }) %>
    <div class="pattern-panel rounded-[2rem] p-8 shadow-sm ring-1 ring-primary/8">
      <p class="text-xs font-bold uppercase tracking-[0.35em] text-primary/38">Editorial Principles</p>
      <div class="mt-5 grid gap-4">
        <% pageContent.editorialPrinciples.forEach((item) => { %>
          <article class="rounded-[1.45rem] bg-white/85 p-5 text-sm leading-7 text-slate-600"><%= item %></article>
        <% }) %>
      </div>
    </div>
  </div>

  <% if (posts.length) { %>
    <div class="mt-12 rounded-[2.2rem] bg-primary p-8 text-white lg:p-10">
      <p class="text-xs font-bold uppercase tracking-[0.35em] text-secondary">Featured Article</p>
      <div class="mt-6 grid gap-8 lg:grid-cols-[1fr,0.8fr] lg:items-end">
        <div>
          <span class="rounded-full border border-white/12 px-4 py-2 text-xs font-semibold uppercase tracking-[0.2em] text-white/72"><%= posts[0].category || 'Article' %></span>
          <h2 class="mt-5 font-display text-4xl font-bold leading-tight"><%= posts[0].title %></h2>
          <p class="mt-4 max-w-2xl text-base leading-8 text-white/72"><%= posts[0].summary %></p>
        </div>
        <div class="flex justify-start lg:justify-end">
          <a href="/blog/<%= posts[0].slug %>" class="rounded-full bg-secondary px-6 py-3 text-sm font-bold text-primary">Read Article</a>
        </div>
      </div>
    </div>
  <% } %>

  <section class="mt-12" data-filter-group>
    <div class="surface-panel rounded-[2rem] p-6 lg:p-8">
      <div class="flex flex-col gap-5 lg:flex-row lg:items-center lg:justify-between">
        <div>
          <p class="text-xs font-bold uppercase tracking-[0.35em] text-primary/38">Browse Articles</p>
          <p class="mt-2 text-sm text-slate-600"><span data-filter-count><%= posts.length %></span> articles available</p>
        </div>
        <input type="search" placeholder="Search articles, tags, or categories" class="w-full rounded-full border border-primary/10 bg-white px-5 py-3 text-sm focus:border-secondary focus:outline-none lg:max-w-md" data-filter-control data-filter-key="search">
      </div>
      <div class="mt-5 flex flex-wrap gap-3">
        <% pageContent.categories.forEach((category, index) => { %>
          <button type="button" class="pill-filter <%= index === 0 ? 'is-active' : '' %>" data-filter-chip data-filter-key="category" data-filter-value="<%= category %>"><%= category %></button>
        <% }) %>
      </div>

      <div class="mt-8 grid gap-6 lg:grid-cols-3">
        <% posts.forEach((post) => { %>
          <article
            class="reveal rounded-[1.9rem] bg-white p-7 shadow-sm ring-1 ring-primary/8"
            data-reveal
            data-filter-item
            data-category="<%= post.category || 'All' %>"
            data-search="<%= `${post.title} ${post.summary} ${post.category || ''} ${(post.tags || []).join(' ')}` %>">
            <p class="text-xs font-bold uppercase tracking-[0.2em] text-secondary"><%= post.category || 'Article' %></p>
            <h2 class="mt-4 font-display text-3xl font-bold text-primary"><%= post.title %></h2>
            <p class="mt-4 text-sm leading-8 text-slate-600"><%= post.summary %></p>
            <div class="mt-6 flex flex-wrap gap-2">
              <% (post.tags || []).slice(0, 3).forEach((tag) => { %>
                <span class="rounded-full bg-slate-100 px-3 py-2 text-xs font-semibold text-slate-600"><%= tag %></span>
              <% }) %>
            </div>
            <a href="/blog/<%= post.slug %>" class="mt-6 inline-flex items-center gap-2 text-sm font-bold text-primary">Read article <span aria-hidden="true">→</span></a>
          </article>
        <% }) %>
      </div>
    </div>
  </section>
</section>

<%- include('../components/team-showcase', {
  eyebrow: 'Leadership and Team',
  title: 'The people behind the editorial and implementation thinking.',
  copy: 'Articles are written from execution experience across leadership, delivery, engineering, and SEO operations, not abstract commentary.'
}) %>

<%- include('../components/site-cta', {
  eyebrow: 'Content System',
  title: 'Need a blog that looks editorial on the frontend and stays manageable in the backend?',
  copy: 'CodexWebz builds the publishing workflow, metadata control, and page templates together so the content system scales cleanly.',
  primaryLabel: 'Talk to CodexWebz',
  primaryHref: '/contact',
  secondaryLabel: 'View Services',
  secondaryHref: '/services'
}) %>

<%- include('../layouts/footer') %>
<%- include('../layouts/scripts') %>
