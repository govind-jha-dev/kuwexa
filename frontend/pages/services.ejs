<%- include('../layouts/head', { title, seo }) %>
<%- include('../layouts/header') %>

<section class="kuwexa-hero text-white">
  <div class="mx-auto max-w-7xl px-6 py-20 lg:px-8 lg:py-28">
    <div class="grid gap-12 lg:grid-cols-[1.02fr,0.98fr] lg:items-start">
      <div class="relative z-[1]">
        <p class="text-xs font-bold uppercase tracking-[0.4em] text-secondary">Capabilities</p>
        <h1 class="mt-6 max-w-5xl font-display text-5xl font-bold leading-[0.98] md:text-6xl lg:text-7xl">
          Kuwexa capabilities for commerce, visibility, platforms, and digital execution.
        </h1>
        <p class="mt-6 max-w-3xl text-lg leading-8 text-white/76">
          These capabilities are designed to support businesses building stronger market presence, better operating systems, and more dependable digital infrastructure.
        </p>
        <div class="mt-10 flex flex-wrap gap-3">
          <% pageContent.marketingServices.slice(0, 6).forEach((item) => { %>
            <span class="rounded-full border border-white/12 px-4 py-2 text-xs font-semibold uppercase tracking-[0.22em] text-white/72"><%= item %></span>
          <% }) %>
        </div>
      </div>

      <div class="hero-stage relative z-[1]">
        <div class="hero-stage__frame orbital-pulse" data-reveal>
          <p class="text-xs font-bold uppercase tracking-[0.35em] text-secondary">Engagement Models</p>
          <div class="mt-6 grid gap-4">
            <% pageContent.engagementModels.forEach((item) => { %>
              <article class="rounded-[1.5rem] border border-white/10 bg-white/10 p-5">
                <h2 class="font-display text-2xl font-bold text-white"><%= item.title %></h2>
                <p class="mt-3 text-sm leading-7 text-white/72"><%= item.copy %></p>
              </article>
            <% }) %>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="mx-auto max-w-7xl px-6 py-20 lg:px-8" data-filter-group>
  <div class="narrative-card reveal" data-reveal>
    <div class="flex flex-col gap-5 lg:flex-row lg:items-center lg:justify-between">
      <div>
        <p class="section-kicker">Capability Filter</p>
        <p class="mt-4 text-sm text-slate-600"><span data-filter-count><%= services.length %></span> capabilities currently shown</p>
      </div>
      <input type="search" placeholder="Search capabilities" class="w-full rounded-full border border-primary/10 bg-white px-5 py-3 text-sm focus:border-secondary focus:outline-none lg:max-w-sm" data-filter-control data-filter-key="search">
    </div>

    <div class="mt-5 flex flex-wrap gap-3">
      <% pageContent.categories.forEach((category, index) => { %>
        <button type="button" class="pill-filter <%= index === 0 ? 'is-active' : '' %>" data-filter-chip data-filter-key="category" data-filter-value="<%= category %>"><%= category %></button>
      <% }) %>
    </div>

    <div class="mt-8 grid gap-6 lg:grid-cols-2">
      <% services.forEach((service) => { %>
        <article
          class="reveal spotlight-card narrative-card"
          data-reveal
          data-filter-item
          data-category="<%= service.profile.category %>"
          data-search="<%= `${service.title} ${service.short_description || ''} ${service.profile.category}` %>">
          <div class="flex flex-wrap items-center justify-between gap-3">
            <span class="rounded-full bg-secondary/15 px-4 py-2 text-xs font-bold uppercase tracking-[0.2em] text-primary"><%= service.profile.category %></span>
            <span class="text-xs font-semibold uppercase tracking-[0.22em] text-primary/35"><%= service.icon || 'Kuwexa Capability' %></span>
          </div>
          <h2 class="mt-5 font-display text-3xl font-bold text-primary"><%= service.title %></h2>
          <p class="mt-4 text-sm leading-8 text-slate-600"><%= service.short_description || service.profile.kicker %></p>
          <div class="mt-6 grid gap-3 sm:grid-cols-2">
            <% service.profile.deliverables.slice(0, 4).forEach((item) => { %>
              <div class="rounded-[1.3rem] bg-slate-50 px-4 py-4 text-sm font-semibold text-slate-700"><%= item %></div>
            <% }) %>
          </div>
          <a href="/services/<%= service.slug %>" class="mt-6 inline-flex items-center gap-2 text-sm font-bold text-primary">Open capability <span aria-hidden="true">&rarr;</span></a>
        </article>
      <% }) %>
    </div>
  </div>
</section>

<section class="mx-auto max-w-7xl px-6 pb-20 lg:px-8">
  <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-4">
    <% pageContent.serviceDepth.forEach((item) => { %>
      <article class="narrative-card reveal" data-reveal>
        <span class="section-kicker">Depth</span>
        <h2 class="mt-5 font-display text-2xl font-bold text-primary"><%= item.title %></h2>
        <p class="mt-4 text-sm leading-8 text-slate-600"><%= item.copy %></p>
      </article>
    <% }) %>
  </div>
</section>

<section class="mx-auto max-w-7xl px-6 pb-20 lg:px-8">
  <div class="narrative-card reveal" data-reveal>
    <%- include('../components/section-heading', {
      eyebrow: 'Full Capability Map',
      title: 'A category-by-category view of the work Kuwexa can present and deliver.',
      copy: 'The capability mix covers the visible frontend, the operating backend, and the growth systems that keep everything connected after launch.'
    }) %>
    <div class="mt-10 grid gap-5 xl:grid-cols-2">
      <% pageContent.serviceCatalog.forEach((group) => { %>
        <article class="rounded-[1.85rem] bg-slate-50 p-6 ring-1 ring-primary/6">
          <p class="text-xs font-bold uppercase tracking-[0.22em] text-secondary">Capability Cluster</p>
          <h2 class="mt-4 font-display text-3xl font-bold text-primary"><%= group.title %></h2>
          <p class="mt-3 text-sm leading-8 text-slate-600"><%= group.summary %></p>
          <div class="mt-6 flex flex-wrap gap-3">
            <% group.items.forEach((item) => { %>
              <span class="rounded-full bg-white px-4 py-2 text-xs font-semibold uppercase tracking-[0.14em] text-primary ring-1 ring-primary/8"><%= item %></span>
            <% }) %>
          </div>
        </article>
      <% }) %>
    </div>
  </div>
</section>

<section class="mx-auto max-w-7xl px-6 pb-20 lg:px-8">
  <div class="grid gap-6 xl:grid-cols-[1.02fr,0.98fr]">
    <div class="narrative-card reveal" data-reveal>
      <span class="section-kicker">Delivery Flow</span>
      <div class="story-grid mt-8">
        <% pageContent.workflow.forEach((item) => { %>
          <article class="story-step">
            <span class="story-step__index"><%= item.step %></span>
            <h3 class="story-step__title"><%= item.title %></h3>
            <p class="story-step__copy"><%= item.copy %></p>
          </article>
        <% }) %>
      </div>
    </div>

    <div class="narrative-card narrative-card--dark reveal" data-reveal>
      <span class="section-kicker !text-white/60 before:!bg-[linear-gradient(90deg,rgba(241,178,74,0.9),rgba(241,178,74,0))]">Who This Helps</span>
      <div class="mt-6 grid gap-4">
        <% pageContent.audiences.forEach((item) => { %>
          <article class="rounded-[1.45rem] border border-white/10 bg-white/6 p-5 text-sm font-semibold leading-7 text-white/78"><%= item %></article>
        <% }) %>
      </div>
    </div>
  </div>
</section>

<section class="mx-auto max-w-7xl px-6 pb-20 lg:px-8">
  <%- include('../components/section-heading', {
    eyebrow: 'Questions',
    title: 'What teams usually ask before the work begins.',
    copy: 'Most early decisions are about operating scope, execution ownership, and how to keep the system usable long after the first launch.'
  }) %>
  <div class="mt-10">
    <%- include('../components/faq-list', { items: pageContent.faqs }) %>
  </div>
</section>

<%- include('../components/site-cta', {
  eyebrow: 'Need a Custom Scope',
  title: 'Start with the capability your business needs most, then expand into a stronger ecosystem over time.',
  copy: 'Kuwexa supports websites, commerce flows, software platforms, SEO systems, integrations, and long-term digital delivery without losing clarity between strategy and execution.',
  primaryLabel: 'Talk to Kuwexa',
  primaryHref: '/contact',
  secondaryLabel: 'See Initiatives',
  secondaryHref: '/portfolio'
}) %>

<%- include('../layouts/footer') %>
<%- include('../layouts/scripts') %>
